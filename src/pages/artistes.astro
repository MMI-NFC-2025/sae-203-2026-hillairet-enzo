---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';

// ==========================================
// 1. CONNEXION POCKETBASE
// ==========================================
const pb = new PocketBase('http://127.0.0.1:8090'); 

let artistes = [];

try {
    const records = await pb.collection('artistes').getFullList();

    artistes = records.map((record) => {
        let formattedDate = "Date à venir";
        if (record.date_representation) {
            const dateObj = new Date(record.date_representation);
            formattedDate = dateObj.toLocaleDateString('fr-FR', { 
                day: '2-digit', 
                month: '2-digit', 
                year: '2-digit' 
            });
        }

        return {
            id: record.id,
            nom: record.nom,
            scene: record.type_de_scene || "À définir",
            date: formattedDate,
            image: record.image_principale ? pb.files.getUrl(record, record.image_principale) : null
        };
    });

} catch (err) {
    console.error("Erreur de connexion à PocketBase :", err);
    artistes = [
        { id: "1", nom: "Danakil", scene: "Scène principale", date: "29/10/26", image: "/assets/images/artistes/danakil.avif" },
        { id: "2", nom: "Tiken Jah Fakoly", scene: "Scène principale", date: "29/10/26", image: "/assets/images/artistes/tiken.avif" },
        { id: "3", nom: "Biga*Ranx", scene: "Scène alternative", date: "29/10/26", image: "/assets/images/artistes/bigaranx.avif" },
        { id: "4", nom: "Jahneration", scene: "Scène principale", date: "30/10/26", image: "/assets/images/artistes/jahneration.avif" },
        { id: "5", nom: "Yaniss Odua", scene: "Scène alternative", date: "30/10/26", image: "/assets/images/artistes/yaniss.avif" },
        { id: "6", nom: "Alborosie", scene: "Scène principale", date: "30/10/26", image: "/assets/images/artistes/alborosie.avif" },
        { id: "7", nom: "Dub Inc", scene: "Scène principale", date: "31/10/26", image: "/assets/images/artistes/dubinc.avif" },
        { id: "8", nom: "Lila Iké", scene: "Scène acoustique", date: "31/10/26", image: "/assets/images/artistes/lila-ike.avif" }
    ];
}

// ==========================================
// 2. TRI PERSONNALISÉ
// ==========================================
const ordreVoulu = [
    "Danakil",
    "Tiken Jah Fakoly",
    "Biga*Ranx",
    "Jahneration",
    "Yaniss Odua",
    "Alborosie",
    "Dub Inc",
    "Lila Iké"
];

artistes.sort((a, b) => {
    let indexA = ordreVoulu.indexOf(a.nom);
    let indexB = ordreVoulu.indexOf(b.nom);
    if (indexA === -1) indexA = 999;
    if (indexB === -1) indexB = 999;
    return indexA - indexB;
});

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];
---

<Layout title="Nos Artistes | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen font-poppins">
        
        <div id="menu-overlay" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out md:left-auto md:w-[500px] lg:w-[600px]">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" onerror="this.style.display='none'" />
                <div class="absolute inset-0 bg-gradient-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-10">
                    <ul class="space-y-4 md:space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li>
                                <a href={link.href} class="block text-2xl md:text-4xl lg:text-5xl font-poppins font-bold text-white uppercase tracking-tight hover:text-[#FED506] transition-colors whitespace-nowrap">
                                    {link.name} <span class="text-white ml-2 md:ml-4">•</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 lg:px-12 xl:px-16 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" />
            </a>
            
            <div class="flex items-center gap-4">
                <button id="user-status-connected" class="hidden font-poppins text-[10px] md:text-xs lg:text-sm uppercase font-bold bg-[#6d9a02] text-white px-4 py-2 lg:px-6 lg:py-3 rounded-full shadow-lg animate-pulse hover:bg-red-600 transition-colors group">
                    <span class="group-hover:hidden">Connecté</span>
                    <span class="hidden group-hover:inline">Déconnexion</span>
                </button>

                <a href="/connexion" id="user-status-disconnected" class="font-poppins text-[10px] md:text-xs lg:text-sm uppercase font-bold bg-[#ED3F24] text-white px-4 py-2 lg:px-6 lg:py-3 rounded-full shadow-lg hover:scale-105 transition-transform">
                    Se connecter
                </a>

                <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group hover:opacity-70 transition-opacity">
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full transition-all"></div>
                </button>
            </div>
        </header>

        <section class="relative w-full h-64 md:h-[500px] lg:h-[60vh] overflow-hidden bg-black flex flex-col justify-center">
            <img src="/assets/images/hero.avif" alt="Platine Vinyle" class="absolute inset-0 w-full h-full object-cover opacity-80" />
            <div class="relative z-10 flex flex-col items-center justify-center p-6 text-center w-full">
                <h1 class="font-display text-5xl md:text-8xl lg:text-[10rem] tracking-wider leading-[0.9] text-center uppercase" 
                    style="color: #ED3F24; -webkit-text-stroke: 3px #FED506; text-shadow: none;">
                    Nos Artistes
                </h1>
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#ED3F24] relative z-40 shadow-lg"></div>

        <section class="w-full py-16 md:py-28 px-6 md:px-10 flex flex-col items-center flex-1">
            <div class="w-full max-w-7xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12 lg:gap-10">
                {artistes.map((artiste) => (
                    <div class="w-full flex flex-col items-center">
                        <a href={`/artistes/${artiste.id}`} class="group relative block w-full h-64 md:h-[350px] lg:h-auto lg:aspect-square rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 hover:scale-[1.02] cursor-pointer">
                            <img src={artiste.image || "/assets/images/section-background.avif"} alt={artiste.nom} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                            
                            <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-all duration-500"></div>
                            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-90"></div>
                            
                            <div class="absolute bottom-6 left-6 md:bottom-8 md:left-8 flex flex-col gap-1 md:gap-2">
                                <h3 class="font-poppins font-bold text-3xl md:text-4xl lg:text-3xl xl:text-4xl text-white tracking-wide group-hover:text-[#FED506] transition-colors">{artiste.nom}</h3>
                                <div class="mt-2 flex flex-col gap-1 text-white/90 font-poppins text-sm md:text-base lg:text-sm xl:text-base">
                                    <p>Date : {artiste.date}</p>
                                    <p>Scène : {artiste.scene}</p>
                                </div>
                            </div>
                        </a>

                        <div class="w-full mt-10 mb-4 lg:hidden flex justify-center">
                            <img src="/assets/images/lignes_rouge_jaune_vert.svg" alt="séparateur" class="w-full h-auto opacity-90 drop-shadow-xl" />
                        </div>
                    </div>
                ))}
            </div>
            
            {artistes.length === 0 && (
                <div class="py-20 text-center text-black font-poppins text-2xl">
                    Aucun artiste disponible pour le moment.
                </div>
            )}
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#6d9a02] relative z-40 shadow-lg"></div>

        <footer class="w-full bg-black text-white pt-24 pb-12 flex flex-col items-center overflow-hidden z-30 mt-auto border-t border-white/10">
            <div class="w-full max-w-7xl flex flex-col items-center lg:items-start px-6">
                
                <div class="w-full font-poppins text-xs md:text-base opacity-60 space-y-1 mt-12 mb-12 text-center lg:text-left flex flex-col lg:flex-row lg:justify-between">
                    <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                    <p>Par Maël BRUNGARD @BooMooN.cloud | ID Étudiant : o4g3yq8bkgg4bxz</p>
                </div>

                <div class="w-full flex flex-col lg:flex-row lg:justify-between items-center">
                    <nav class="mb-12 lg:mb-0">
                        <ul class="flex flex-wrap justify-center lg:justify-start items-center gap-x-12 gap-y-6 font-poppins font-bold text-sm md:text-xl uppercase">
                            {navLinks.map((link, index) => (
                                <>
                                    <li><a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a></li>
                                    {index < navLinks.length - 1 && <li class="hidden md:block opacity-30">•</li>}
                                </>
                            ))}
                        </ul>
                    </nav>

                    <nav class="flex gap-10 font-poppins text-[10px] md:text-xs uppercase underline opacity-40">
                        <a href="#">CGU</a><a href="#">CGV</a><a href="#">Mentions Légales</a>
                    </nav>
                </div>
            </div>
        </footer>
    </div>
</Layout>

<script>
    // --- IMPORT BACKEND ---
    import { pb, logoutUser } from '../../backend/backend.mjs';

    // --- LOGIQUE DU MENU ---
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');
    
    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { 
            overlay.classList.remove('translate-x-full'); 
            document.body.style.overflow = 'hidden'; 
        });
        menuClose.addEventListener('click', () => { 
            overlay.classList.add('translate-x-full'); 
            document.body.style.overflow = ''; 
        });
    }

    // --- LOGIQUE BOUTONS STATUT ---
    const btnConnected = document.getElementById('user-status-connected');
    const btnDisconnected = document.getElementById('user-status-disconnected');

    function updateHeader() {
        if (pb && pb.authStore && pb.authStore.isValid) {
            btnConnected?.classList.remove('hidden');
            btnDisconnected?.classList.add('hidden');
        } else {
            btnConnected?.classList.add('hidden');
            btnDisconnected?.classList.remove('hidden');
        }
    }

    // Action de déconnexion au clic sur le bouton vert
    btnConnected?.addEventListener('click', () => {
        if(typeof logoutUser === 'function') logoutUser();
        else pb.authStore.clear();
        window.location.reload();
    });

    updateHeader();
</script>

<style>
    html { scroll-behavior: smooth; }
</style>