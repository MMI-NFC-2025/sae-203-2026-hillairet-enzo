---
import Layout from '../layouts/Layout.astro';

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];
---

<Layout title="Connexion | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen font-poppins">
        
        <div id="menu-overlay" class="fixed inset-0 z-100 translate-x-full transition-transform duration-500 ease-in-out md:left-auto md:w-125 lg:w-150">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" />
                <div class="absolute inset-0 bg-linear-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-10">
                    <ul class="space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li>
                                <a href={link.href} class="block text-2xl md:text-4xl lg:text-5xl font-poppins font-bold text-white uppercase tracking-tight hover:text-[#FED506] transition-colors whitespace-nowrap">
                                    {link.name} <span class="text-white ml-2 md:ml-4">•</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 lg:px-12 xl:px-16 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" />
            </a>
            <div class="flex items-center gap-4">
                <span id="user-status" class="hidden font-poppins text-[10px] md:text-xs uppercase font-bold bg-[#6d9a02] text-white px-4 py-2 lg:px-6 lg:py-3 rounded-full shadow-lg animate-pulse">Connecté</span>
                <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group hover:opacity-70 transition-opacity">
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full transition-all"></div>
                </button>
            </div>
        </header>

        <section class="w-full pt-12 pb-16 md:pt-16 flex justify-center text-center px-4">
            <h1 class="font-display text-5xl sm:text-7xl md:text-8xl lg:text-[10rem] tracking-wider leading-[0.9] text-center uppercase" 
                style="color: #ED3F24; -webkit-text-stroke: 3px #FED506; text-shadow: none;">
                Espace Membre
            </h1>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#ED3F24] relative z-40 shadow-lg"></div>

        <section class="w-full py-24 px-6 md:px-10 flex flex-col items-center justify-center flex-1 relative">
            
            <div class="relative z-10 w-full max-w-md min-h-137.5 rounded-[3rem] overflow-hidden shadow-2xl border border-black/10 transition-transform duration-500 hover:scale-[1.01]">
                
                <img src="/assets/images/licorn-bg.avif" alt="Fond Carte" class="absolute inset-0 w-full h-full object-cover scale-110 blur-sm rounded-[3rem]" />
                <div class="absolute inset-0 bg-black/60 backdrop-blur-md rounded-[3rem]"></div>

                <div class="relative z-10 p-8 md:p-14 flex flex-col h-full text-white">
                    
                    <div id="login-zone" class="w-full">
                        <h2 class="font-righteous text-3xl md:text-4xl mb-4 drop-shadow-md text-center uppercase tracking-widest">
                            Heureux de vous revoir !
                        </h2>
                        <p class="font-poppins text-white/60 mb-10 text-sm text-center">Connectez-vous pour accéder à vos avantages.</p>

                        <form id="login-form" class="flex flex-col gap-6">
                            <div class="flex flex-col gap-2">
                                <label for="email" class="font-poppins font-bold text-xs uppercase tracking-[0.2em] text-white/80 ml-1">Email</label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    required
                                    placeholder="votre@email.com" 
                                    class="w-full bg-white/10 border border-white/20 rounded-2xl py-4 px-6 text-white placeholder:text-white/30 focus:outline-none focus:border-[#FED506] focus:bg-white/20 transition-all backdrop-blur-xl"
                                />
                            </div>

                            <div class="flex flex-col gap-2">
                                <label for="password" class="font-poppins font-bold text-xs uppercase tracking-[0.2em] text-white/80 ml-1">Mot de passe</label>
                                <input 
                                    type="password" 
                                    id="password" 
                                    required
                                    placeholder="••••••••" 
                                    class="w-full bg-white/10 border border-white/20 rounded-2xl py-4 px-6 text-white placeholder:text-white/30 focus:outline-none focus:border-[#FED506] focus:bg-white/20 transition-all backdrop-blur-xl"
                                />
                            </div>

                            <p id="error-message" class="text-[#ed3f24] font-poppins font-bold text-sm hidden bg-red-500/10 p-4 rounded-2xl border border-red-500/20 text-center">
                                ⚠️ Identifiants incorrects.
                            </p>

                            <button 
                                type="submit" 
                                class="w-full mt-4 bg-[#ED3F24] hover:bg-[#FED506] text-white hover:text-black font-poppins font-bold text-xl py-5 rounded-3xl transition-all shadow-xl active:scale-95 border-none uppercase tracking-widest"
                            >
                                Se connecter
                            </button>
                        </form>
                    </div>

                    <div id="logout-zone" class="hidden flex flex-col items-center justify-center flex-1 text-center py-10" style="display: none;">
                        <div class="w-24 h-24 bg-[#6d9a02]/20 rounded-full flex items-center justify-center mb-8 border border-[#6d9a02]/30 shadow-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-[#6d9a02]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                        <h2 class="font-righteous text-3xl mb-4 uppercase tracking-widest">Accès autorisé</h2>
                        <p class="font-poppins text-white/70 mb-12">Vous êtes actuellement authentifié sur Echos Sonores.</p>
                        
                        <button id="logout-btn" class="w-full bg-[#ED3F24] hover:bg-[#FED506] hover:text-black text-white font-poppins font-bold text-xl py-5 rounded-3xl transition-all shadow-xl active:scale-95 border border-white/10 uppercase tracking-widest">
                            Se déconnecter
                        </button>
                    </div>

                </div>
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#6d9a02] relative z-40 shadow-lg"></div>

        <footer class="w-full bg-black text-white pt-16 pb-12 flex flex-col items-center mt-auto border-t border-white/10 z-30">
            <div class="w-full max-w-7xl flex flex-col items-center lg:items-start px-6">
                <div class="w-full font-poppins text-xs md:text-base opacity-40 mb-12 text-center lg:text-left flex flex-col lg:flex-row lg:justify-between border-b border-white/5 pb-12 gap-4">
                    <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                    <p>Par Maël BRUNGARD @BooMooN.cloud | ID Étudiant : o4g3yq8bkgg4bxz</p>
                </div>

                <div class="w-full flex flex-col lg:flex-row lg:justify-between items-center gap-8">
                    <nav>
                        <ul class="flex flex-wrap justify-center lg:justify-start items-center gap-x-12 gap-y-6 font-poppins font-bold text-sm md:text-xl uppercase">
                            {navLinks.map((link, i) => (
                                <li class="flex items-center gap-12">
                                    <a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a>
                                    {i < navLinks.length - 1 && <span class="opacity-20 hidden md:block select-none">•</span>}
                                </li>
                            ))}
                        </ul>
                    </nav>
                    <nav class="flex gap-10 font-poppins text-[10px] md:text-xs uppercase underline opacity-40">
                        <a href="#">CGU</a><a href="#">CGV</a><a href="#">Mentions Légales</a>
                    </nav>
                </div>
            </div>
        </footer>
    </div>
</Layout>

<script>
    import { loginUser, logoutUser, pb } from '../../backend/backend.mjs';

    // --- MENU ---
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');

    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { 
            overlay.classList.remove('translate-x-full'); 
            document.body.style.overflow = 'hidden'; 
        });
        menuClose.addEventListener('click', () => { 
            overlay.classList.add('translate-x-full'); 
            document.body.style.overflow = ''; 
        });
    }

    // --- UI UPDATER ---
    const loginForm = document.getElementById('login-form') as HTMLFormElement;
    const loginZone = document.getElementById('login-zone');
    const logoutZone = document.getElementById('logout-zone');
    const logoutBtn = document.getElementById('logout-btn');
    const errorMessage = document.getElementById('error-message');
    const userStatus = document.getElementById('user-status');

    function updateUI() {
        const isConnected = pb.authStore.isValid;
        
        if (isConnected) {
            loginZone?.classList.add('hidden');
            logoutZone?.classList.remove('hidden');
            logoutZone?.classList.add('flex');
            userStatus?.classList.remove('hidden');
        } else {
            loginZone?.classList.remove('hidden');
            logoutZone?.classList.add('hidden');
            logoutZone?.classList.remove('flex');
            userStatus?.classList.add('hidden');
        }
    }

    updateUI();

    // --- ACTIONS ---
    loginForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;
        
        const success = await loginUser(email, password);
        
        if (success) {
            errorMessage?.classList.add('hidden');
            updateUI();
        } else {
            errorMessage?.classList.remove('hidden');
        }
    });

    logoutBtn?.addEventListener('click', () => {
        if(typeof logoutUser === 'function') logoutUser();
        else pb.authStore.clear();
        updateUI();
        window.location.reload();
    });
</script>

<style>
    html { scroll-behavior: smooth; }
</style>