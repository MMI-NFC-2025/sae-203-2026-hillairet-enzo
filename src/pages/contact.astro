---
import Layout from '../layouts/Layout.astro';

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];
---

<Layout title="Contact | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen font-poppins">
        
        <div id="menu-overlay" class="fixed inset-0 z-100 translate-x-full transition-transform duration-500 ease-in-out md:left-auto md:w-125 lg:w-150">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" />
                <div class="absolute inset-0 bg-linear-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-10">
                    <ul class="space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li>
                                <a href={link.href} class="block text-2xl md:text-4xl lg:text-5xl font-poppins font-bold text-white uppercase hover:text-[#FED506] transition-colors whitespace-nowrap">
                                    {link.name} <span class="text-white ml-2 md:ml-4">•</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 lg:px-12 xl:px-16 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" />
            </a>

            <div class="flex items-center gap-4">
                <button id="user-status-connected" class="hidden font-poppins text-[10px] md:text-xs uppercase font-bold bg-[#6d9a02] text-white px-4 py-2 rounded-full shadow-lg group hover:bg-red-600 transition-colors">
                    <span class="group-hover:hidden">Connecté</span>
                    <span class="hidden group-hover:inline">Déconnexion</span>
                </button>
                <a href="/connexion" id="user-status-disconnected" class="font-poppins text-[10px] md:text-xs uppercase font-bold bg-[#ED3F24] text-white px-4 py-2 rounded-full shadow-lg hover:scale-105 transition-transform">
                    Se connecter
                </a>

                <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group hover:opacity-70 transition-opacity">
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full transition-all"></div>
                </button>
            </div>
        </header>

        <section class="w-full pt-12 pb-16 md:pt-16 flex justify-center text-center px-4">
            <h1 class="font-display text-4xl sm:text-6xl md:text-7xl lg:text-[7rem] tracking-wider leading-[0.9] text-center uppercase" 
                style="color: #ED3F24; -webkit-text-stroke: 3px #FED506; text-shadow: none;">
                Formulaire de contact
            </h1>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#ED3F24] relative z-40 shadow-lg"></div>

        <section class="w-full py-24 px-6 md:px-10 flex flex-col items-center flex-1">
            <div class="relative w-full max-w-2xl min-h-150 rounded-[3rem] overflow-hidden shadow-2xl border border-black/10">
                <div class="absolute inset-0 z-0">
                    <img src="/assets/images/licorn-bg.avif" alt="Fond Contact" class="w-full h-full object-cover scale-110 blur-sm" />
                    <div class="absolute inset-0 bg-black/40"></div>
                </div>

                <div class="relative z-10 p-8 md:p-16 flex flex-col h-full">
                    <h2 class="font-poppins font-bold text-3xl md:text-5xl text-white mb-10 drop-shadow-md">
                        Contactez Nous !
                    </h2>

                    <form class="flex flex-col gap-8" id="contact-form">
                        <div class="flex flex-col gap-3">
                            <label for="email" class="font-poppins font-bold text-xl text-white">Email</label>
                            <input 
                                type="email" 
                                id="email" 
                                required
                                placeholder="Votre Email" 
                                class="w-full bg-black/30 border border-white/20 rounded-2xl py-4 px-6 text-white placeholder:text-white/40 focus:outline-none focus:border-[#FED506] transition-colors backdrop-blur-md"
                            />
                        </div>

                        <div class="flex flex-col gap-3">
                            <label for="subject" class="font-poppins font-bold text-xl text-white">Sujet</label>
                            <input 
                                type="text" 
                                id="subject" 
                                required
                                placeholder="Sujet" 
                                class="w-full bg-black/30 border border-white/20 rounded-2xl py-4 px-6 text-white placeholder:text-white/40 focus:outline-none focus:border-[#FED506] transition-colors backdrop-blur-md"
                            />
                        </div>

                        <div class="flex flex-col gap-3">
                            <label for="message" class="font-poppins font-bold text-xl text-white">Votre Message</label>
                            <textarea 
                                id="message" 
                                required
                                rows="5" 
                                class="w-full bg-black/30 border border-white/20 rounded-2xl py-4 px-6 text-white focus:outline-none focus:border-[#FED506] transition-colors backdrop-blur-md resize-none"
                            ></textarea>
                        </div>

                        <button 
                            type="submit" 
                            id="submit-btn"
                            class="w-full mt-4 bg-[#1e1e1e] hover:bg-black text-white font-poppins font-bold text-2xl py-5 rounded-3xl transition-all shadow-xl active:scale-95 border border-white/5"
                        >
                            Envoyer
                        </button>
                        
                        <p id="form-status" class="hidden text-center font-bold text-lg mt-4 px-4 py-2 rounded-xl"></p>
                    </form>
                </div>
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#FED506] relative z-40 shadow-lg"></div>

        <section class="w-full py-16 flex flex-col items-center bg-[#FEFAF5]">
            <div class="flex gap-6">
                <a href="https://facebook.com" target="_blank" class="w-14 h-14 bg-black text-white rounded-full flex items-center justify-center hover:bg-[#FED506] hover:text-black transition-all shadow-lg hover:-translate-y-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                </a>
                <a href="https://instagram.com" target="_blank" class="w-14 h-14 bg-black text-white rounded-full flex items-center justify-center hover:bg-[#FED506] hover:text-black transition-all shadow-lg hover:-translate-y-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </a>
                <a href="https://tiktok.com" target="_blank" class="w-14 h-14 bg-black text-white rounded-full flex items-center justify-center hover:bg-[#FED506] hover:text-black transition-all shadow-lg hover:-translate-y-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
                </a>
                <a href="https://twitter.com" target="_blank" class="w-14 h-14 bg-black text-white rounded-full flex items-center justify-center hover:bg-[#FED506] hover:text-black transition-all shadow-lg hover:-translate-y-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
                </a>
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#6d9a02] relative z-40 shadow-lg"></div>

        <footer class="w-full bg-black text-white pt-16 pb-12 flex flex-col items-center mt-auto border-t border-white/10 z-30">
            <div class="w-full max-w-7xl flex flex-col items-center lg:items-start px-6">
                
                <div class="w-full font-poppins text-xs md:text-base opacity-40 mb-12 text-center lg:text-left flex flex-col lg:flex-row lg:justify-between border-b border-white/5 pb-12 gap-4">
                    <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                    <p>Par Maël BRUNGARD @BooMooN.cloud | ID Étudiant : o4g3yq8bkgg4bxz</p>
                </div>

                <div class="w-full flex flex-col lg:flex-row lg:justify-between items-center gap-8">
                    <nav>
                        <ul class="flex flex-wrap justify-center lg:justify-start items-center gap-x-12 gap-y-6 font-poppins font-bold text-sm md:text-xl uppercase">
                            {navLinks.map((link, i) => (
                                <li class="flex items-center gap-12">
                                    <a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a>
                                    {i < navLinks.length - 1 && <span class="opacity-20 hidden md:block select-none">•</span>}
                                </li>
                            ))}
                        </ul>
                    </nav>
                    <nav class="flex gap-10 font-poppins text-[10px] md:text-xs uppercase underline opacity-40">
                        <a href="#">CGU</a><a href="#">CGV</a><a href="#">Mentions Légales</a>
                    </nav>
                </div>
            </div>
        </footer>
    </div>
</Layout>

<script>
    import { pb, logoutUser } from '../../backend/backend.mjs';

    // --- LOGIQUE DU MENU ---
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');
    
    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { 
            overlay.classList.remove('translate-x-full'); 
            document.body.style.overflow = 'hidden'; 
        });
        menuClose.addEventListener('click', () => { 
            overlay.classList.add('translate-x-full'); 
            document.body.style.overflow = ''; 
        });
    }

    // --- LOGIQUE BOUTONS STATUT ---
    const btnConnected = document.getElementById('user-status-connected');
    const btnDisconnected = document.getElementById('user-status-disconnected');

    function updateHeader() {
        if (pb && pb.authStore && pb.authStore.isValid) {
            btnConnected?.classList.remove('hidden');
            btnDisconnected?.classList.add('hidden');
        } else {
            btnConnected?.classList.add('hidden');
            btnDisconnected?.classList.remove('hidden');
        }
    }

    btnConnected?.addEventListener('click', () => {
        if(typeof logoutUser === 'function') logoutUser();
        else pb.authStore.clear(); 
        window.location.reload();
    });

    updateHeader();

    // --- LOGIQUE ENVOI FORMULAIRE POCKETBASE ---
    const contactForm = document.getElementById('contact-form') as HTMLFormElement;
    const statusMsg = document.getElementById('form-status');
    const submitBtn = document.getElementById('submit-btn');

    if (contactForm) {
        contactForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            // Récupération des valeurs
            const email = (document.getElementById('email') as HTMLInputElement).value;
            const subject = (document.getElementById('subject') as HTMLInputElement).value;
            const message = (document.getElementById('message') as HTMLTextAreaElement).value;

            const data = {
                email,
                subject,
                message
            };

            // Désactivation du bouton pendant l'envoi
            if (submitBtn) (submitBtn as HTMLButtonElement).disabled = true;

            try {
                // Envoi à la collection 'contact' de PocketBase
                await pb.collection('contact').create(data);

                // Feedback succès
                if (statusMsg) {
                    statusMsg.innerText = "Message envoyé avec succès !";
                    statusMsg.className = "block text-center font-bold text-lg mt-4 px-4 py-2 rounded-xl bg-green-500/20 text-green-500 border border-green-500/50";
                }
                
                // Reset du formulaire
                contactForm.reset();

            } catch (error) {
                // Feedback erreur
                if (statusMsg) {
                    statusMsg.innerText = "Erreur lors de l'envoi. Veuillez réessayer.";
                    statusMsg.className = "block text-center font-bold text-lg mt-4 px-4 py-2 rounded-xl bg-red-500/20 text-red-500 border border-red-500/50";
                }
                console.error("Erreur PocketBase :", error);
            } finally {
                // Réactivation du bouton
                if (submitBtn) (submitBtn as HTMLButtonElement).disabled = false;
            }
        });
    }
</script>

<style>
    html { scroll-behavior: smooth; }
</style>