---
import Layout from '../layouts/Layout.astro';

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];
---

<Layout title="Contact | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen">
        
        <div id="menu-overlay" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" onerror="this.style.display='none'" />
                <div class="absolute inset-0 bg-gradient-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" onerror="this.style.display='none'" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-20">
                    <ul class="space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li>
                                <a href={link.href} class="block text-2xl md:text-5xl font-poppins font-bold text-white uppercase hover:text-[#FED506] transition-colors">
                                    {link.name} <span class="text-white ml-2 md:ml-4">•</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" onerror="this.style.display='none'" />
            </a>
            <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group">
                <div class="w-10 md:w-12 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                <div class="w-10 md:w-12 h-1 bg-black rounded-full transition-all"></div>
            </button>
        </header>

        <section class="w-full pt-4 pb-12 flex justify-center text-center px-4">
            <h1 class="font-display text-4xl sm:text-6xl md:text-[6rem] text-black uppercase tracking-tight">
                Formulaire de contact
            </h1>
        </section>

        <section class="w-full pb-24 px-6 md:px-10 flex flex-col items-center flex-1">
            
            <div class="relative w-full max-w-2xl min-h-[600px] rounded-[3rem] overflow-hidden shadow-2xl border border-black/10">
                
                <div class="absolute inset-0 z-0">
                    <img src="/assets/images/licorn-bg.avif" alt="Fond Contact" class="w-full h-full object-cover scale-110 blur-sm" />
                    <div class="absolute inset-0 bg-black/40"></div>
                </div>

                <div class="relative z-10 p-8 md:p-16 flex flex-col h-full">
                    <h2 class="font-poppins font-bold text-3xl md:text-5xl text-white mb-10 drop-shadow-md">
                        Contactez Nous !
                    </h2>

                    <form class="flex flex-col gap-8">
                        <div class="flex flex-col gap-3">
                            <label for="email" class="font-poppins font-bold text-xl text-white">Email</label>
                            <input 
                                type="email" 
                                id="email" 
                                placeholder="Votre Email" 
                                class="w-full bg-black/30 border border-white/20 rounded-2xl py-4 px-6 text-white placeholder:text-white/40 focus:outline-none focus:border-[#FED506] transition-colors backdrop-blur-md"
                            />
                        </div>

                        <div class="flex flex-col gap-3">
                            <label for="subject" class="font-poppins font-bold text-xl text-white">Sujet</label>
                            <input 
                                type="text" 
                                id="subject" 
                                placeholder="Sujet" 
                                class="w-full bg-black/30 border border-white/20 rounded-2xl py-4 px-6 text-white placeholder:text-white/40 focus:outline-none focus:border-[#FED506] transition-colors backdrop-blur-md"
                            />
                        </div>

                        <div class="flex flex-col gap-3">
                            <label for="message" class="font-poppins font-bold text-xl text-white">Votre Message</label>
                            <textarea 
                                id="message" 
                                rows="5" 
                                class="w-full bg-black/30 border border-white/20 rounded-2xl py-4 px-6 text-white focus:outline-none focus:border-[#FED506] transition-colors backdrop-blur-md resize-none"
                            ></textarea>
                        </div>

                        <button 
                            type="submit" 
                            class="w-full mt-4 bg-[#1e1e1e] hover:bg-black text-white font-poppins font-bold text-2xl py-5 rounded-3xl transition-all shadow-xl active:scale-95 border border-white/5"
                        >
                            Envoyer
                        </button>
                    </form>
                </div>

            </div>
        </section>

        <footer class="w-full bg-black text-white pt-24 pb-12 flex flex-col items-center overflow-hidden z-30 mt-auto">
            <div class="font-poppins text-[10px] sm:text-xs md:text-base opacity-40 mb-12 text-center text-balance px-4 leading-relaxed">
                <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                <p>Par Maël BRUNGARD @BooMooN.cloud</p>
            </div>
            <nav class="mb-12 px-4 text-center">
                <ul class="flex flex-wrap justify-center items-center gap-x-6 sm:gap-x-12 gap-y-6 font-poppins font-bold text-xs sm:text-sm md:text-xl uppercase">
                    {navLinks.map((link, i) => (
                        <li class="flex items-center gap-6 sm:gap-12">
                            <a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a>
                            {i < navLinks.length - 1 && <span class="opacity-20 hidden md:block select-none">•</span>}
                        </li>
                    ))}
                </ul>
            </nav>
            <nav class="flex flex-wrap justify-center gap-6 sm:gap-10 font-poppins text-[9px] sm:text-[10px] md:text-xs uppercase underline opacity-40 text-center px-4">
                <a href="#">CGU</a><a href="#">CGV</a><a href="#">Mentions Légales</a>
            </nav>
        </footer>
    </div>
</Layout>

<script>
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');
    
    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { 
            overlay.classList.remove('translate-x-full'); 
            document.body.style.overflow = 'hidden'; 
        });
        menuClose.addEventListener('click', () => { 
            overlay.classList.add('translate-x-full'); 
            document.body.style.overflow = ''; 
        });
    }
</script>

<style>
    html { scroll-behavior: smooth; }
</style>