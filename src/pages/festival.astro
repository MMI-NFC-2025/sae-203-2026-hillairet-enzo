---
import Layout from '../layouts/Layout.astro';

// 1. Liens rapides
const quickLinks = [
    { title: "Notre histoire", href: "#histoire", img: "/assets/images/cards/histoire.avif" },
    { title: "Notre équipe", href: "#equipe", img: "/assets/images/cards/equipe.avif" },
    { title: "Édition 2026", href: "#edition", img: "/assets/images/cards/2026.avif" }
];

// 2. Histoire
const historySteps = [
    { title: "La naissance d’une équipe", text: "Ce projet a démarré dans le cadre d'un travail étudiant en MMI. Ce projet a fini par se concrétiser et est devenu le festival que vous connaissez." },
    { title: "Notre premier festival", text: "En 2026 nous organiserons notre premier festival de reggae. Ce festival vise tout public et a pour but de rendre le reggae accessible." },
    { title: "Nos projets à venir", text: "Nous visons à égaler les meilleurs festivals et à donner une nouvelle image plus propre aux festivals de musique." }
];

// 3. Équipe
const teamCategories = [
    {
        name: "Logistique",
        members: [
            { name: "Valentine Dupont", role: "Chef de projet", img: "/assets/images/team/team1.avif", bio: "Valentine est responsable de la coordination globale du projet." },
            { name: "Pedro Silva", role: "Logistique", img: "/assets/images/team/team2.avif", bio: "Pedro gère tous les aspects logistiques du festival." },
            { name: "Maxence Martin", role: "Directeur artistique", img: "/assets/images/team/team3.avif", bio: "Maxence est en charge de la sélection des artistes." }
        ]
    },
    {
        name: "Son & Technique",
        members: [
            { name: "Léa Bernard", role: "Ingénieure son", img: "/assets/images/team/team4.avif", bio: "Léa supervise la qualité sonore de l'événement." },
            { name: "Constance Dubois", role: "Lumière", img: "/assets/images/team/team5.avif", bio: "Constance est responsable de la conception des effets lumineux." },
            { name: "Roxanne Lefèvre", role: "Sécurité", img: "/assets/images/team/team6.avif", bio: "Roxanne coordonne les mesures de sécurité." }
        ]
    },
    {
    name: "Support",
        members: [
            { name: "Evan Moreau", role: "Coordinateur support", img: "/assets/images/team/team7.avif", bio: "Evan assure le support opérationnel pendant le festival." },
            { name: "Nina Rousseau", role: "Assistante logistique", img: "/assets/images/team/team8.avif", bio: "Nina assiste Pedro dans la gestion logistique." },
            { name: "Camille Fontaine", role: "Presse", img: "/assets/images/team/team9.avif", bio: "Camille travaille aux côtés d'Evan pour fournir un support technique." }
        ]
    }
];

// 4. Édition 2026
const themes = [
    { label: "Festival de la ", bold: "culture reggae" },
    { label: "Festival de la ", bold: "création artistique" },
    { label: "Festival de l'", bold: "innovation locale" },
    { label: "Festival de l'", bold: "engagement citoyen" }
];

const values = [
    { name: "Convivialité", img: "/assets/icons/valeurs/conv.avif" },
    { name: "Écologie", img: "/assets/icons/valeurs/eco.avif" },
    { name: "Créativité", img: "/assets/icons/valeurs/crea.avif" }
];

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];
---

<Layout title="Le Festival | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen font-poppins">
        
        <div id="menu-overlay" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out md:left-auto md:w-[500px] lg:w-[600px]">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" />
                <div class="absolute inset-0 bg-gradient-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-10">
                    <ul class="space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li><a href={link.href} class="block text-2xl md:text-4xl lg:text-5xl font-bold text-white uppercase tracking-tight hover:text-[#FED506] transition-colors whitespace-nowrap">{link.name} <span class="text-white ml-2 md:ml-4">•</span></a></li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 lg:px-12 xl:px-16 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" />
            </a>
            
            <div class="flex items-center gap-4">
                <button id="user-status-connected" class="hidden text-[10px] md:text-xs lg:text-sm uppercase font-bold bg-[#6d9a02] text-white px-4 py-2 lg:px-6 lg:py-3 rounded-full shadow-lg hover:bg-red-600 transition-colors group">
                    <span class="group-hover:hidden">Connecté</span>
                    <span class="hidden group-hover:inline">Déconnexion</span>
                </button>

                <a href="/connexion" id="user-status-disconnected" class="text-[10px] md:text-xs lg:text-sm uppercase font-bold bg-[#ED3F24] text-white px-4 py-2 lg:px-6 lg:py-3 rounded-full shadow-lg hover:scale-105 transition-transform">
                    Se connecter
                </a>

                <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group hover:opacity-70 transition-opacity">
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full transition-all"></div>
                </button>
            </div>
        </header>

        <section class="relative w-full overflow-hidden bg-black h-72 sm:h-96 md:h-[500px] lg:h-[70vh] flex flex-col justify-center">
            <img src="/assets/images/hero.avif" alt="Hero Festival" class="absolute inset-0 w-full h-full object-cover opacity-80" />
            <div class="relative z-10 bg-black/40 flex items-center justify-center p-6 lg:p-20 h-full w-full">
                <h1 class="font-display text-6xl md:text-9xl lg:text-[12rem] tracking-wider leading-[0.9] text-center uppercase" 
                    style="color: #ED3F24; -webkit-text-stroke: 3px #FED506; text-shadow: none;">
                    Le Festival
                </h1>
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#ED3F24] relative z-40 shadow-lg"></div>

        <section class="w-full bg-[#FFF4C6] py-16 md:py-24 px-6 flex flex-col items-center">
            <div class="w-full max-w-7xl flex flex-col md:flex-row items-stretch justify-center gap-6 md:gap-8 lg:gap-12">
                {quickLinks.map((link, index) => (
                    <>
                        <a href={link.href} class="group relative w-full md:flex-1 h-48 md:h-64 lg:h-auto lg:aspect-square rounded-2xl overflow-hidden shadow-xl transition-all duration-500 hover:scale-[1.03]">
                            <img src={link.img} alt={link.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                            <div class="absolute inset-0 bg-black/50 group-hover:bg-black/20 transition-all duration-500"></div>
                            <div class="absolute bottom-6 left-8 lg:bottom-10 lg:left-10">
                                <h3 class="font-poppins font-bold text-2xl md:text-3xl lg:text-4xl text-white uppercase tracking-widest leading-tight group-hover:text-[#FED506] transition-colors">{link.title}</h3>
                            </div>
                        </a>
                        {index < quickLinks.length - 1 && (
                            <div class="w-full block md:hidden py-4">
                                <img src="/assets/images/lignes_rouge_jaune_vert.svg" alt="separateur" class="w-full h-auto opacity-60" />
                            </div>
                        )}
                    </>
                ))}
            </div>
        </section>

        <section id="histoire" class="relative w-full py-20 md:py-40 flex flex-col items-center scroll-mt-20">
            <div class="absolute inset-0 w-full h-full z-0 overflow-hidden">
                <img src="/assets/images/section-background.avif" alt="" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-black/75"></div> 
            </div>

            <h2 class="relative z-10 font-righteous text-4xl sm:text-5xl md:text-7xl lg:text-7xl text-white mb-16 md:mb-24 text-center uppercase tracking-widest leading-none drop-shadow-lg">
                Notre histoire
            </h2>
            
            <div class="relative z-10 w-full max-w-7xl flex flex-col md:flex-row items-stretch justify-center gap-8 lg:gap-12 px-6">
                {historySteps.map((step, index) => (
                    <>
                        <div class="w-full md:flex-1 flex flex-col group">
                            <div class="w-full h-full p-8 md:p-10 lg:p-12 lg:aspect-square rounded-[30px] bg-white/60 backdrop-blur-xl border border-white/10 shadow-2xl hover:bg-white/90 transition-all duration-500 flex flex-col justify-center text-center md:text-left group-hover:-translate-y-4">
                                <h3 class="font-poppins font-bold text-xl md:text-2xl lg:text-3xl text-black mb-4 uppercase tracking-tight">{step.title}</h3>
                                <p class="font-poppins text-black text-base md:text-lg lg:text-xl leading-relaxed opacity-90">{step.text}</p>
                            </div>
                        </div>
                        {index < historySteps.length - 1 && (
                            <div class="w-full block md:hidden py-8">
                                <img src="/assets/images/lignes_rouge_jaune_vert.svg" class="w-full h-auto opacity-40" />
                            </div>
                        )}
                    </>
                ))}
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#FED506] relative z-40 shadow-lg"></div>

        <section id="equipe" class="w-full bg-[#FEFAF5] py-24 md:py-40 flex flex-col items-center scroll-mt-20">
            <h2 class="font-righteous text-4xl sm:text-5xl md:text-7xl lg:text-7xl text-black mb-16 md:mb-24 uppercase tracking-widest text-center px-4 leading-none">
                Notre équipe
            </h2>
            
            <div class="w-full max-w-7xl space-y-16 lg:space-y-24">
                {teamCategories.map((cat) => (
                    <div class="flex flex-col items-center w-full">
                        <h3 class="font-poppins font-bold text-2xl md:text-3xl lg:text-4xl mb-12 lg:mb-16 uppercase tracking-[0.3em] text-black">
                            {cat.name}
                        </h3>
                        
                        <div class="flex flex-row overflow-x-auto no-scrollbar md:grid md:grid-cols-3 items-center justify-center gap-6 md:gap-12 w-full px-6 pb-8">
                            {cat.members.map((member, index) => (
                                <div class="flex flex-row items-center justify-center gap-6 shrink-0 md:flex-col md:shrink md:w-full">
                                    <button class="team-trigger group outline-none cursor-pointer flex flex-col items-center gap-4" data-name={member.name} data-role={member.role} data-bio={member.bio} data-img={member.img}>
                                        <div class={`rounded-full overflow-hidden border-4 border-transparent group-hover:border-[#ED3F24] transition-all duration-300 shadow-xl group-hover:scale-105 
                                            ${index === 1 
                                                ? 'w-24 h-24 md:w-52 md:h-52 lg:w-72 lg:h-72' 
                                                : 'w-16 h-16 md:w-40 md:h-40 lg:w-56 lg:h-56'
                                            }`}>
                                            <img src={member.img} alt={member.name} class="w-full h-full object-cover transition-all duration-500 group-hover:grayscale-0 grayscale-[30%]" />
                                        </div>
                                        <div class="hidden md:flex flex-col items-center mt-4">
                                            <span class="font-poppins font-bold text-lg lg:text-2xl text-black uppercase group-hover:text-[#ED3F24] transition-colors">{member.name}</span>
                                            <span class="font-poppins text-sm lg:text-base text-black font-medium uppercase tracking-widest">{member.role}</span>
                                        </div>
                                    </button>
                                    
                                    {index < cat.members.length - 1 && (
                                        <span class="text-black text-2xl font-black opacity-30 select-none md:hidden">•</span>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#6d9a02] relative z-40 shadow-lg"></div>

        <section id="edition" class="relative w-full py-24 md:py-40 px-6 flex flex-col items-center scroll-mt-20 overflow-hidden">
            <div class="absolute inset-0 w-full h-full z-0">
                <img src="/assets/images/licorn-bg.avif" alt="Fond" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
            </div>
            <div class="relative z-10 w-full max-w-7xl">
                <h2 class="font-righteous text-4xl sm:text-5xl md:text-7xl lg:text-7xl text-white text-center mb-16 md:mb-24 uppercase tracking-widest leading-none drop-shadow-lg">
                    Édition 2026
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-20 md:gap-40 items-start">
                    <div class="space-y-12 text-center md:text-left bg-black/40 p-8 lg:p-12 rounded-[30px] border border-white/10 backdrop-blur-md">
                        <h3 class="font-poppins font-bold text-2xl md:text-4xl text-white uppercase tracking-widest text-center md:text-left">Thématiques</h3>
                        <ul class="space-y-6">
                            {themes.map((theme) => (
                                <li class="flex items-center gap-6 text-white font-poppins text-lg md:text-2xl lg:text-3xl text-left hover:translate-x-4 transition-transform duration-300">
                                    <span class="w-3 h-3 bg-[#ED3F24] rounded-full shrink-0"></span>
                                    <p>{theme.label}<span class="font-bold text-white">{theme.bold}</span></p>
                                </li>
                            ))}
                        </ul>
                    </div>
                    
                    <div class="space-y-12 bg-black/40 p-8 lg:p-12 rounded-[30px] border border-white/10 backdrop-blur-md">
                        <h3 class="font-poppins font-bold text-2xl md:text-4xl text-white uppercase tracking-widest text-center">Valeurs</h3>
                        <div class="grid grid-cols-3 gap-6 lg:gap-10">
                            {values.map((value) => (
                                <div class="flex flex-col items-center gap-4 group">
                                    <div class="w-16 h-16 md:w-24 md:h-24 lg:w-32 lg:h-32 transition-transform duration-500 group-hover:scale-110 group-hover:-translate-y-2">
                                        <img src={value.img} alt={value.name} class="w-full h-full object-contain brightness-0 invert opacity-90 group-hover:opacity-100" />
                                    </div>
                                    <p class="font-poppins font-bold text-white text-[10px] md:text-xs lg:text-sm uppercase text-center tracking-widest group-hover:text-[#FED506] transition-colors">{value.name}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <footer class="w-full bg-black text-white pt-16 pb-12 flex flex-col items-center mt-auto border-t border-white/10 z-30">
            <div class="w-full max-w-7xl flex flex-col items-center lg:items-start px-6">

                <div class="w-full font-poppins text-xs md:text-base opacity-40 mb-12 text-center lg:text-left flex flex-col lg:flex-row lg:justify-between border-b border-white/5 pb-12 gap-4">
                    <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                    <p>Par Maël BRUNGARD @BooMooN.cloud | ID Étudiant : o4g3yq8bkgg4bxz</p>
                </div>

                <div class="w-full flex flex-col lg:flex-row lg:justify-between items-center gap-8">
                    <nav>
                        <ul class="flex flex-wrap justify-center lg:justify-start items-center gap-x-12 gap-y-6 font-bold text-sm md:text-xl uppercase">
                            {navLinks.map((link, i) => (
                                <li class="flex items-center gap-12">
                                    <a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a>
                                    {i < navLinks.length - 1 && <span class="opacity-20 hidden md:block select-none">•</span>}
                                </li>
                            ))}
                        </ul>
                    </nav>
                    <nav class="flex gap-10 text-[10px] md:text-xs uppercase underline opacity-40">
                        <a href="#">CGU</a><a href="#">CGV</a><a href="#">Mentions Légales</a>
                    </nav>
                </div>
            </div>
        </footer>

        <div id="team-modal" class="fixed inset-0 z-[200] hidden flex items-center justify-center p-4">
            <div id="modal-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-sm cursor-pointer"></div>
            <div id="modal-content" class="relative bg-[#FFF4C6] w-full max-w-2xl rounded-[2rem] p-8 md:p-12 shadow-2xl scale-95 transition-transform duration-300 flex flex-col md:flex-row gap-8 items-center border border-black/10">
                <button id="modal-close-btn" class="absolute top-4 right-4 text-black hover:text-[#ED3F24] transition-colors p-2 bg-black/5 rounded-full">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
                <div class="w-40 h-40 md:w-56 md:h-56 shrink-0 rounded-full overflow-hidden border-4 border-[#ED3F24] shadow-xl">
                    <img id="modal-img" src="" alt="Team Member" class="w-full h-full object-cover" />
                </div>
                <div class="flex flex-col text-center md:text-left">
                    <h3 id="modal-name" class="font-display text-4xl text-black uppercase mb-1"></h3>
                    <p id="modal-role" class="font-poppins font-bold text-[#ED3F24] uppercase tracking-widest text-sm mb-6"></p>
                    <p id="modal-bio" class="font-poppins text-black/80 text-sm md:text-base leading-relaxed"></p>
                </div>
            </div>
        </div>

    </div>
</Layout>

<script>
    import { pb, logoutUser } from '../../backend/backend.mjs';

    // --- MENU ---
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');
    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { overlay.classList.remove('translate-x-full'); document.body.style.overflow = 'hidden'; });
        menuClose.addEventListener('click', () => { overlay.classList.add('translate-x-full'); document.body.style.overflow = ''; });
    }

    // --- MODAL EQUIPE ---
    const teamTriggers = document.querySelectorAll('.team-trigger');
    const teamModal = document.getElementById('team-modal');
    const modalContent = document.getElementById('modal-content');
    const modalCloseBtn = document.getElementById('modal-close-btn');
    const modalOverlay = document.getElementById('modal-overlay');
    
    const mImg = document.getElementById('modal-img') as HTMLImageElement;
    const mName = document.getElementById('modal-name');
    const mRole = document.getElementById('modal-role');
    const mBio = document.getElementById('modal-bio');

    teamTriggers.forEach(btn => {
        btn.addEventListener('click', () => {
            if(mImg) mImg.src = btn.getAttribute('data-img') || '';
            if(mName) mName.innerText = btn.getAttribute('data-name') || '';
            if(mRole) mRole.innerText = btn.getAttribute('data-role') || '';
            if(mBio) mBio.innerText = btn.getAttribute('data-bio') || '';
            
            teamModal?.classList.remove('hidden');
            setTimeout(() => modalContent?.classList.remove('scale-95'), 10);
            document.body.style.overflow = 'hidden';
        });
    });

    const closeTeamModal = () => { 
        modalContent?.classList.add('scale-95');
        setTimeout(() => { teamModal?.classList.add('hidden'); document.body.style.overflow = ''; }, 200);
    };
    modalCloseBtn?.addEventListener('click', closeTeamModal);
    modalOverlay?.addEventListener('click', closeTeamModal);

    // --- AUTH STATUS ---
    const btnConnected = document.getElementById('user-status-connected');
    const btnDisconnected = document.getElementById('user-status-disconnected');

    function updateHeader() {
        if (pb && pb.authStore && pb.authStore.isValid) {
            btnConnected?.classList.remove('hidden');
            btnDisconnected?.classList.add('hidden');
        } else {
            btnConnected?.classList.add('hidden');
            btnDisconnected?.classList.remove('hidden');
        }
    }

    btnConnected?.addEventListener('click', () => {
        if(typeof logoutUser === 'function') logoutUser();
        else pb.authStore.clear();
        window.location.reload();
    });

    updateHeader();
</script>

<style>
    html { scroll-behavior: smooth; }
    .font-display { font-family: 'Magic Vintage', cursive; }
    .font-righteous { font-family: 'Righteous', cursive; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>