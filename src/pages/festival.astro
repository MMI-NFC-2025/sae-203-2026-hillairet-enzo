---
import Layout from '../layouts/Layout.astro';

// 1. Liens rapides
const quickLinks = [
    { title: "Notre histoire", href: "#histoire", img: "/assets/images/cards/histoire.avif" },
    { title: "Notre équipe", href: "#equipe", img: "/assets/images/cards/equipe.avif" },
    { title: "Édition 2026", href: "#edition", img: "/assets/images/cards/2026.avif" }
];

// 2. Histoire
const historySteps = [
    { title: "La naissance d’une équipe", text: "Ce projet a démarré dans le cadre d'un travail étudiant en MMI. Ce projet a fini par se concrétiser et est devenu le festival que vous connaissez." },
    { title: "Notre premier festival", text: "En 2026, nous organiserons notre premier festival de reggae. Ce festival vise tout public et a pour but de rendre le reggae accessible." },
    { title: "Nos projets à venir", text: "Nous visons à égaler les meilleurs festivals et à donner une nouvelle image plus propre aux festivals de musique." }
];

// 3. Équipe
const teamCategories = [
    {
        name: "Logistique",
        members: [
            { name: "Valentine Dupont", role: "Chef de projet", img: "/assets/images/team/team1.avif", bio: "Valentine est responsable de la coordination globale du projet." },
            { name: "Pedro Silva", role: "Logistique", img: "/assets/images/team/team2.avif", bio: "Pedro gère tous les aspects logistiques du festival." },
            { name: "Maxence Martin", role: "Directeur artistique", img: "/assets/images/team/team3.avif", bio: "Maxence est en charge de la sélection des artistes." }
        ]
    },
    {
        name: "Son & Technique",
        members: [
            { name: "Léa Bernard", role: "Ingénieure son", img: "/assets/images/team/team4.avif", bio: "Léa supervise la qualité sonore de l'événement." },
            { name: "Constance Dubois", role: "Lumière", img: "/assets/images/team/team5.avif", bio: "Constance est responsable de la conception des effets lumineux." },
            { name: "Roxanne Lefèvre", role: "Sécurité", img: "/assets/images/team/team6.avif", bio: "Roxanne coordonne les mesures de sécurité." }
        ]
    }
];

const themes = [
    { label: "Festival de la ", bold: "culture reggae" },
    { label: "Festival de la ", bold: "création artistique" },
    { label: "Festival de l'", bold: "innovation locale" },
    { label: "Festival de l'", bold: "engagement citoyen" }
];

const values = [
    { name: "Convivialité", img: "/assets/icons/valeurs/conv.avif" },
    { name: "Écologie", img: "/assets/icons/valeurs/eco.avif" },
    { name: "Créativité", img: "/assets/icons/valeurs/crea.avif" }
];

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];
---

<Layout title="Le Festival | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen">
        
        <div id="menu-overlay" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" />
                <div class="absolute inset-0 bg-gradient-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-20">
                    <ul class="space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li><a href={link.href} class="block text-3xl md:text-5xl font-poppins font-bold text-white uppercase hover:text-[#FED506] transition-colors">{link.name} •</a></li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" />
            </a>
            
            <div class="flex items-center gap-4">
                <button id="user-status-connected" class="hidden font-poppins text-[10px] md:text-xs uppercase font-bold bg-[#6d9a02] text-white px-3 py-1.5 rounded-full shadow-lg animate-pulse hover:bg-red-600 transition-colors">
                    Connecté
                </button>

                <a href="/connexion" id="user-status-disconnected" class="font-poppins text-[10px] md:text-xs uppercase font-bold bg-[#ED3F24] text-white px-3 py-1.5 rounded-full shadow-lg hover:scale-105 transition-transform">
                    Se connecter
                </a>

                <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group">
                    <div class="w-10 md:w-12 h-1 bg-black rounded-full"></div>
                    <div class="w-10 md:w-12 h-1 bg-black rounded-full"></div>
                </button>
            </div>
        </header>

        <section class="relative w-full overflow-hidden bg-black">
            <img src="/assets/images/hero.avif" alt="Hero Festival" class="w-full h-auto block" />
            <div class="absolute inset-0 bg-black/40 flex items-center justify-center p-6">
                <h1 class="font-display text-5xl md:text-8xl lg:text-[11rem] text-white uppercase italic text-center leading-none">
                    Le Festival
                </h1>
            </div>
        </section>

        <section class="w-full bg-[#FFF4C6] py-16 md:py-24 px-6 flex flex-col items-center">
            <div class="w-full max-w-7xl flex flex-col md:flex-row items-stretch justify-center gap-6 md:gap-8">
                {quickLinks.map((link) => (
                    <a href={link.href} class="group relative w-full md:flex-1 h-48 md:h-64 rounded-2xl overflow-hidden shadow-xl transition-all duration-500 hover:scale-[1.03]">
                        <img src={link.img} alt={link.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                        <div class="absolute inset-0 bg-black/50 group-hover:bg-black/30 transition-all duration-500"></div>
                        <div class="absolute bottom-6 left-8">
                            <h3 class="font-poppins font-bold text-2xl md:text-3xl text-white uppercase tracking-widest">{link.title}</h3>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        <section id="histoire" class="relative w-full py-20 md:py-40 flex flex-col items-center scroll-mt-20">
            <div class="absolute inset-0 w-full h-full z-0 overflow-hidden">
                <img src="/assets/images/section-background.avif" alt="" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-black/75"></div> 
            </div>
            <h2 class="relative z-10 font-display text-5xl md:text-[10rem] text-white mb-24 text-center uppercase italic opacity-95">Notre histoire</h2>
            <div class="relative z-10 w-full max-w-7xl flex flex-col md:flex-row gap-8 px-6">
                {historySteps.map((step) => (
                    <div class="w-full md:flex-1 p-8 md:p-10 rounded-[30px] bg-white/60 backdrop-blur-xl border border-white/10 shadow-2xl">
                        <h3 class="font-poppins font-bold text-xl md:text-2xl text-black mb-4 uppercase">{step.title}</h3>
                        <p class="font-poppins text-black text-base md:text-lg leading-relaxed opacity-90">{step.text}</p>
                    </div>
                ))}
            </div>
        </section>

        <footer class="w-full bg-black text-white pt-24 pb-12 flex flex-col items-center">
            <div class="font-poppins text-xs md:text-base opacity-40 mb-12 text-center">
                <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                <p>Par Maël BRUNGARD @BooMooN.cloud | ID : o4g3yq8bkgg4bxz</p>
            </div>
        </footer>
    </div>

    <div id="team-modal" class="fixed inset-0 z-[150] flex items-center justify-center hidden px-4">
        <div id="modal-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-md"></div>
        <div class="relative z-10 w-full max-w-md bg-black/80 backdrop-blur-3xl border border-white/10 p-10 rounded-[40px] shadow-2xl text-white text-center">
            <h3 id="modal-name" class="font-poppins font-bold text-3xl mb-1"></h3>
            <p id="modal-role" class="text-[#FED506] uppercase mb-4"></p>
            <p id="modal-bio" class="opacity-80"></p>
            <button id="modal-close-btn" class="mt-8 px-8 py-2 border border-white/20 rounded-full cursor-pointer hover:bg-white hover:text-black">Fermer</button>
        </div>
    </div>
</Layout>

<script>
    // --- IMPORT BACKEND ---
    import { pb, logoutUser } from '../../backend/backend.mjs';

    // --- LOGIQUE MENU ---
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');

    menuOpen?.addEventListener('click', () => {
        overlay?.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
    });
    menuClose?.addEventListener('click', () => {
        overlay?.classList.add('translate-x-full');
        document.body.style.overflow = '';
    });

    // --- LOGIQUE BOUTONS STATUT ---
    const btnConnected = document.getElementById('user-status-connected');
    const btnDisconnected = document.getElementById('user-status-disconnected');

    function updateHeader() {
        if (pb && pb.authStore.isValid) {
            btnConnected?.classList.remove('hidden');
            btnDisconnected?.classList.add('hidden');
        } else {
            btnConnected?.classList.add('hidden');
            btnDisconnected?.classList.remove('hidden');
        }
    }

    // Action de déconnexion au clic sur le bouton vert
    btnConnected?.addEventListener('click', () => {
        logoutUser();
        window.location.reload();
    });

    updateHeader();
</script>

<style>
    html { scroll-behavior: smooth; }
</style>