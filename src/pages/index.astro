---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Echos Sonores - Accueil">
	<button class="bg-red-600 text-white p-10 text-3xl font-bold rounded-full shadow-2xl">
  SI TU VOIS CE BOUTON ROUGE, TAILWIND MARCHE !
</button>
  
  <section class="relative min-h-screen flex flex-col justify-between items-center bg-[#fff4c6] overflow-hidden pt-20">
    
    <header class="absolute top-0 w-full p-6 flex justify-between items-center z-50">
      <img src="/assets/favicon/favicon-96x96.png" alt="Logo" class="w-12 h-12" />
      <button class="flex flex-col gap-2 group">
        <span class="w-8 h-1 bg-[#130e0a] rounded-full"></span>
        <span class="w-8 h-1 bg-[#130e0a] rounded-full"></span>
      </button>
    </header>

    <div class="flex flex-col items-center text-center px-4 flex-grow justify-center gap-8">
      
      <h1 class="text-6xl md:text-9xl font-['Righteous'] text-[#130e0a] uppercase tracking-tighter leading-none">
        Echos Sonore
      </h1>

      <div class="flex flex-col items-center gap-6">
        <h2 class="text-3xl md:text-5xl font-bold leading-tight text-[#130e0a]">
          Vibrez<br />au rythme de la nature
        </h2>
        
        <div class="flex flex-col items-center gap-1 uppercase tracking-[0.2em] font-black text-[#6d9a02] text-sm md:text-base">
          <span>Festival de Reggae</span>
          <span>du 29 au 31 octobre</span>
          <span>Audincourt, 25400</span>
        </div>

        <img 
          src="/assets/images/mascotte.avif" 
          alt="Mascotte Echos Sonores" 
          class="h-64 md:h-80 object-contain mt-4"
        />
      </div>
    </div>

    <a href="#billetterie" class="mb-12 animate-bounce">
      <img src="/assets/icons/scroll-down.svg" alt="Scroll" class="w-10 h-10" />
    </a>

    <div class="w-full flex h-3">
      <div class="flex-1 bg-[#ed3f24]"></div>
      <div class="flex-1 bg-[#fed506]"></div>
      <div class="flex-1 bg-[#6d9a02]"></div>
    </div>

  </section>

</Layout>