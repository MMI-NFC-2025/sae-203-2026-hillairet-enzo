---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';

// ==========================================
// 1. CONNEXION POCKETBASE
// ==========================================
const pb = new PocketBase('http://127.0.0.1:8090'); // Ton URL PocketBase

let concerts = [];
try {
    // Remplacer 'artistes' par le nom exact de ta collection si besoin
    const records = await pb.collection('artistes').getFullList({
        sort: '+date_representation', // Trie chronologiquement par date
    });

    // On extrait toutes les dates uniques (ex: ["2026-12-29", "2026-12-30"]) pour créer Jour 1, Jour 2...
    const uniqueDates = [...new Set(records.map(r => r.date_representation.substring(0, 10)))].sort();

    // On formate les données avec TES vrais noms de colonnes
    concerts = records.map((record) => {
        // Détermine si c'est le Jour 1, 2 ou 3 selon la date
        const dateStr = record.date_representation.substring(0, 10);
        const dayNum = uniqueDates.indexOf(dateStr) + 1;

        return {
            id: record.id,
            nom: record.nom,
            genre: record.genre_musical,     // Correspond à ta BDD
            scene: record.type_de_scene,     // Correspond à ta BDD
            horaire: record.moment_journee,  // Correspond à ta BDD
            jour: `Jour ${dayNum}`,          // Généré automatiquement !
            image: record.image_principale ? pb.files.getUrl(record, record.image_principale) : null // Correspond à ta BDD
        };
    });

} catch (err) {
    console.error("Erreur de connexion à PocketBase :", err);
    // Données de secours
    concerts = [
        { id: "1", nom: "Danakil", genre: "Reggae", scene: "Scène principale", horaire: "Soirée", jour: "Jour 1", image: "/assets/images/artistes/danakil.avif" },
        { id: "2", nom: "Tiken Jah Fakoly", genre: "Reggae", scene: "Scène principale", horaire: "Nuit", jour: "Jour 1", image: "/assets/images/artistes/tiken.avif" },
        { id: "3", nom: "Biga*Ranx", genre: "Dub", scene: "Scène alternative", horaire: "Nuit", jour: "Jour 1", image: "/assets/images/artistes/bigaranx.avif" },
        { id: "4", nom: "Jahneration", genre: "Reggae", scene: "Scène principale", horaire: "Soirée", jour: "Jour 2", image: "/assets/images/artistes/jahneration.avif" },
        { id: "5", nom: "Yaniss Odua", genre: "Reggae", scene: "Scène alternative", horaire: "Soirée", jour: "Jour 2", image: "/assets/images/artistes/yaniss.avif" },
        { id: "6", nom: "Alborosie", genre: "Roots", scene: "Scène principale", horaire: "Nuit", jour: "Jour 2", image: "/assets/images/artistes/alborosie.avif" },
        { id: "7", nom: "Dub Inc", genre: "Reggae", scene: "Scène principale", horaire: "Soirée", jour: "Jour 3", image: "/assets/images/artistes/dubinc.avif" },
        { id: "8", nom: "Lila Iké", genre: "Pop", scene: "Scène acoustique", horaire: "Après-midi", jour: "Jour 3", image: "/assets/images/artistes/lila-ike.avif" },
        { id: "9", nom: "Protoje", genre: "Roots", scene: "Scène alternative", horaire: "Nuit", jour: "Jour 3", image: "/assets/images/artistes/protoje.avif" },
    ];
}

// 2. LOGIQUE AUTOMATIQUE DES JOURS ET FILTRES
const groupedConcerts = {};
// On initialise le Set de genres avec "Rock" pour forcer son apparition
const genresSet = new Set(["Rock"]); 
const horairesSet = new Set();
const scenesSet = new Set();

concerts.forEach(c => {
    // Groupement par jour
    if(!groupedConcerts[c.jour]) groupedConcerts[c.jour] = [];
    groupedConcerts[c.jour].push(c);
    
    // Récupération des filtres uniques depuis ta BDD
    if(c.genre) genresSet.add(c.genre);
    if(c.horaire) horairesSet.add(c.horaire);
    if(c.scene) scenesSet.add(c.scene);
});

const days = Object.keys(groupedConcerts).sort();

const filtres = {
    genre: Array.from(genresSet).sort(),
    horaire: Array.from(horairesSet).sort(),
    scene: Array.from(scenesSet).sort()
};

// 3. Navigation
const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];

const programDays = [
    { title: "Jour 1", img: "/assets/images/artistes/danakil.avif", date: "Vendredi 10 Juillet" },
    { title: "Jour 2", img: "/assets/images/artistes/jahneration.avif", date: "Samedi 11 Juillet" },
    { title: "Jour 3", img: "/assets/images/artistes/dub-inc.avif", date: "Dimanche 12 Juillet" }
];
---

<Layout title="Programme | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen">
        
        <div id="menu-overlay" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" />
                <div class="absolute inset-0 bg-gradient-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-20">
                    <ul class="space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li>
                                <a href={link.href} class="block text-2xl md:text-5xl font-poppins font-bold text-white uppercase hover:text-[#FED506] transition-colors">
                                    {link.name} <span class="text-white ml-2 md:ml-4">•</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto" />
            </a>
            <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group">
                <div class="w-10 md:w-12 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                <div class="w-10 md:w-12 h-1 bg-black rounded-full transition-all"></div>
            </button>
        </header>

        <section class="relative w-full overflow-hidden bg-black">
            <img src="/assets/images/hero.avif" alt="Hero Programme" class="w-full h-auto block opacity-80" />
            <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center bg-black/30">
                <h1 class="font-display text-4xl sm:text-6xl md:text-8xl lg:text-[10rem] text-[#FED506] uppercase italic leading-none drop-shadow-[0_4px_0_rgba(185,28,28,1)]">
                    Notre Programme
                </h1>
                <a href="/assets/programme.pdf" download class="mt-4 md:mt-12 font-poppins font-bold text-white uppercase tracking-widest border-b-2 border-white hover:text-[#FED506] hover:border-[#FED506] transition-all text-sm md:text-2xl">
                    Téléchargement PDF
                </a>
            </div>
        </section>

        <section class="w-full py-12 md:py-24 px-4 md:px-10 flex flex-col items-center">
            <div class="w-full max-w-7xl flex flex-col md:flex-row items-stretch justify-center gap-6 md:gap-8">
                {programDays.map((day, index) => (
                    <>
                        <div class="group relative w-full md:flex-1 h-48 sm:h-56 md:h-[450px] rounded-2xl overflow-hidden shadow-xl transition-all duration-500 hover:scale-[1.03] cursor-pointer" onclick={`filterByDay('${day.title}')`}>
                            <img src={day.img} alt={day.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                            <div class="absolute bottom-4 left-6 md:bottom-8 md:left-8">
                                <h3 class="font-poppins font-bold text-2xl md:text-4xl text-white uppercase tracking-widest">{day.title}</h3>
                                <p class="font-poppins text-white/70 text-xs md:text-lg uppercase tracking-wider mt-1">{day.date}</p>
                            </div>
                        </div>
                        {index < programDays.length - 1 && (
                            <div class="w-full block md:hidden py-2">
                                <img src="/assets/images/lignes_rouge_jaune_vert.svg" alt="separateur" class="w-full h-auto opacity-60" />
                            </div>
                        )}
                    </>
                ))}
            </div>
        </section>

        <section class="w-full bg-[#1e1e1e] py-16 flex flex-col items-center shadow-inner">
            <h2 class="font-display text-4xl md:text-5xl text-white mb-12 tracking-widest">Filtres</h2>
            
            <div class="flex flex-wrap justify-center gap-8 md:gap-16 font-poppins font-bold text-white text-lg md:text-2xl mb-8">
                {filtres.genre.length > 0 && (
                    <button class="hover:text-[#FED506] transition-colors flex items-center gap-2" onclick="toggleSubFilters('genre')">
                        Genre <span id="arrow-genre" class="text-sm">▼</span>
                    </button>
                )}
                {filtres.horaire.length > 0 && (
                    <button class="hover:text-[#FED506] transition-colors flex items-center gap-2" onclick="toggleSubFilters('horaire')">
                        Horaire <span id="arrow-horaire" class="text-sm">▼</span>
                    </button>
                )}
                {filtres.scene.length > 0 && (
                    <button class="hover:text-[#FED506] transition-colors flex items-center gap-2" onclick="toggleSubFilters('scene')">
                        Scène <span id="arrow-scene" class="text-sm">▼</span>
                    </button>
                )}
            </div>

            <div class="min-h-[60px] flex flex-col items-center w-full">
                <div id="options-genre" class="filter-group hidden flex flex-wrap justify-center gap-4 max-w-3xl px-6">
                    {filtres.genre.map(g => (
                        <button class="filter-btn px-6 py-2 border border-white/40 rounded-xl bg-[#333333] text-white font-poppins text-sm md:text-base hover:bg-white hover:text-black transition-all" data-type="genre" data-value={g}>{g}</button>
                    ))}
                </div>
                <div id="options-horaire" class="filter-group hidden flex flex-wrap justify-center gap-4 max-w-3xl px-6">
                    {filtres.horaire.map(h => (
                        <button class="filter-btn px-6 py-2 border border-white/40 rounded-xl bg-[#333333] text-white font-poppins text-sm md:text-base hover:bg-white hover:text-black transition-all" data-type="horaire" data-value={h}>{h}</button>
                    ))}
                </div>
                <div id="options-scene" class="filter-group hidden flex flex-wrap justify-center gap-4 max-w-3xl px-6">
                    {filtres.scene.map(s => (
                        <button class="filter-btn px-6 py-2 border border-white/40 rounded-xl bg-[#333333] text-white font-poppins text-sm md:text-base hover:bg-white hover:text-black transition-all" data-type="scene" data-value={s}>{s}</button>
                    ))}
                </div>
                
                <button id="reset-filters" class="hidden mt-8 px-8 py-2 border border-[#FED506] text-[#FED506] rounded-xl font-poppins text-sm md:text-base hover:bg-[#FED506] hover:text-black transition-all">
                    Tout afficher
                </button>
            </div>
        </section>

        <div id="concerts-grid" class="w-full flex flex-col">
            {days.length === 0 ? (
                 <div class="w-full py-20 text-center text-black font-poppins text-2xl">
                     Aucun concert trouvé dans la base de données.
                 </div>
            ) : (
                days.map((day, index) => {
                    const isLight = index % 2 !== 0; 
                    
                    let bgImage = null;
                    if (day === 'Jour 1') bgImage = '/assets/images/section-background.avif';
                    else if (day === 'Jour 3') bgImage = '/assets/images/licorn-bg.avif';
                    else if (!isLight) bgImage = '/assets/images/section-background.avif'; 
                    
                    return (
                        <section class={`day-section relative w-full py-20 flex flex-col items-center overflow-hidden min-h-[500px] ${isLight ? 'bg-[#FEFAF5]' : ''}`} data-day-section={day}>
                            
                            {!isLight && bgImage && (
                                <div class="absolute inset-0 z-0">
                                    <img src={bgImage} alt="Ambiance" class="w-full h-full object-cover absolute" />
                                    <div class="absolute inset-0 bg-black/75"></div>
                                </div>
                            )}

                            <div class="relative z-10 w-full max-w-4xl px-4 flex flex-col items-center">
                                <h2 class={`font-poppins font-bold text-4xl md:text-6xl mb-16 text-center tracking-widest uppercase ${isLight ? 'text-black' : 'text-white'}`}>
                                    {day}
                                </h2>
                                
                                <div class="w-full flex flex-col items-center">
                                    {groupedConcerts[day].map((concert, idx) => (
                                        <div class="concert-wrapper w-full flex flex-col items-center" 
                                             data-scene={concert.scene} 
                                             data-genre={concert.genre} 
                                             data-horaire={concert.horaire}
                                             data-jour={concert.jour}>
                                            
                                            <a href={`/artistes/${concert.id}`} class="relative w-full h-[220px] md:h-[400px] rounded-3xl overflow-hidden shadow-2xl group border border-white/10 block cursor-pointer">
                                                <img src={concert.image || "/assets/images/section-background.avif"} alt={concert.nom} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                                                
                                                <div class="absolute inset-0 bg-gradient-to-br from-black/80 via-transparent to-transparent opacity-90"></div>
                                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-70"></div>
                                                
                                                <div class="absolute top-5 left-6 md:top-8 md:left-10">
                                                    <h3 class="font-poppins font-bold text-2xl md:text-5xl text-white tracking-wide">{concert.nom}</h3>
                                                </div>

                                                <div class="absolute bottom-5 right-6 md:bottom-8 md:right-10 flex flex-col items-end gap-2 md:opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                                    <span class="inline-block px-3 py-1 bg-[#FED506] text-black font-bold text-xs md:text-sm rounded-full uppercase tracking-widest shadow-lg">{concert.horaire}</span>
                                                    <span class="inline-block px-3 py-1 bg-black/60 text-white font-poppins text-xs md:text-sm rounded-full uppercase tracking-widest border border-white/20 backdrop-blur-md">{concert.scene}</span>
                                                </div>
                                            </a>
                                            
                                            <div class="separator w-full py-8 md:py-12">
                                                <img src="/assets/images/lignes_rouge_jaune_vert.svg" alt="separateur" class="w-full h-auto opacity-90 drop-shadow-xl" />
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </section>
                    );
                })
            )}

            <div id="no-results" class="hidden text-white font-poppins text-xl md:text-2xl my-16 text-center bg-[#1e1e1e] border border-[#FED506] px-8 py-4 rounded-2xl shadow-xl mx-auto max-w-max">
                Aucun artiste ne correspond à ces filtres.
            </div>
        </div>

        <a href="/assets/programme.pdf" download class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-[90] bg-white text-black px-4 py-3 md:px-6 md:py-4 rounded-2xl shadow-2xl flex items-center gap-3 md:gap-4 hover:scale-110 transition-transform active:scale-95 group border border-black/5">
            <span class="font-poppins font-bold uppercase tracking-widest text-xs md:text-base">PDF</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-8 md:w-8 group-hover:translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
        </a>

        <footer class="w-full bg-black text-white pt-24 pb-12 flex flex-col items-center overflow-hidden z-30 mt-auto">
            <div class="font-poppins text-[10px] sm:text-xs md:text-base opacity-40 mb-12 text-center text-balance px-4 leading-relaxed">
                <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                <p>Par Maël BRUNGARD @BooMooN.cloud</p>
            </div>
            <nav class="mb-12 px-4 text-center">
                <ul class="flex flex-wrap justify-center items-center gap-x-6 sm:gap-x-12 gap-y-6 font-poppins font-bold text-xs sm:text-sm md:text-xl uppercase">
                    {navLinks.map((link, i) => (
                        <li class="flex items-center gap-6 sm:gap-12">
                            <a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a>
                            {i < navLinks.length - 1 && <span class="opacity-20 hidden md:block select-none">•</span>}
                        </li>
                    ))}
                </ul>
            </nav>
            <nav class="flex flex-wrap justify-center gap-6 sm:gap-10 font-poppins text-[9px] sm:text-[10px] md:text-xs uppercase underline opacity-40 text-center px-4">
                <a href="#">CGU</a><a href="#">CGV</a><a href="#">Mentions Légales</a>
            </nav>
        </footer>
    </div>
</Layout>

<script>
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');
    
    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { 
            overlay.classList.remove('translate-x-full'); 
            document.body.style.overflow = 'hidden'; 
        });
        menuClose.addEventListener('click', () => { 
            overlay.classList.add('translate-x-full'); 
            document.body.style.overflow = ''; 
        });
    }

    let activeGroup = null;

    window.toggleSubFilters = function(group) {
        document.querySelectorAll('.filter-group').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('span[id^="arrow-"]').forEach(el => el.innerText = '▼');

        if (activeGroup === group) {
            activeGroup = null;
        } else {
            document.getElementById(`options-${group}`).classList.remove('hidden');
            document.getElementById(`arrow-${group}`).innerText = '▲';
            activeGroup = group;
        }
    }

    const filterBtns = document.querySelectorAll('.filter-btn');
    const daySections = document.querySelectorAll('.day-section');
    const resetBtn = document.getElementById('reset-filters');
    const noResultsMsg = document.getElementById('no-results');

    let currentFilterType = null;
    let currentFilterValue = null;
    let currentDayFilter = null; 

    window.filterByDay = function(dayTitle) {
        currentDayFilter = dayTitle;
        resetBtn.classList.remove('hidden');
        applyFilters();
        document.getElementById('concerts-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            const type = e.target.getAttribute('data-type');
            const val = e.target.getAttribute('data-value');
            
            filterBtns.forEach(b => {
                b.classList.remove('bg-white', 'text-black', 'border-transparent');
                b.classList.add('bg-[#333333]', 'text-white', 'border-white/40');
            });
            e.target.classList.remove('bg-[#333333]', 'text-white', 'border-white/40');
            e.target.classList.add('bg-white', 'text-black', 'border-transparent');

            currentFilterType = type;
            currentFilterValue = val;
            resetBtn.classList.remove('hidden');
            applyFilters();
        });
    });

    resetBtn.addEventListener('click', () => {
        currentFilterType = null;
        currentFilterValue = null;
        currentDayFilter = null;
        
        filterBtns.forEach(b => {
            b.classList.remove('bg-white', 'text-black', 'border-transparent');
            b.classList.add('bg-[#333333]', 'text-white', 'border-white/40');
        });
        
        document.querySelectorAll('.filter-group').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('span[id^="arrow-"]').forEach(el => el.innerText = '▼');
        activeGroup = null;

        resetBtn.classList.add('hidden');
        applyFilters();
    });

    function applyFilters() {
        let totalVisible = 0;

        daySections.forEach(section => {
            let sectionVisibleCount = 0;
            const wrappers = section.querySelectorAll('.concert-wrapper');
            let lastVisibleWrapper = null;

            wrappers.forEach(wrapper => {
                let showCard = true;

                if (currentFilterType && currentFilterValue) {
                    if (wrapper.getAttribute(`data-${currentFilterType}`) !== currentFilterValue) {
                        showCard = false;
                    }
                }

                if (currentDayFilter) {
                    if (wrapper.getAttribute('data-jour') !== currentDayFilter) {
                        showCard = false;
                    }
                }

                if (showCard) {
                    wrapper.style.display = 'flex';
                    wrapper.querySelector('.separator').style.display = 'block';
                    sectionVisibleCount++;
                    totalVisible++;
                    lastVisibleWrapper = wrapper;
                } else {
                    wrapper.style.display = 'none';
                }
            });

            if (lastVisibleWrapper) {
                lastVisibleWrapper.querySelector('.separator').style.display = 'none';
            }

            if (sectionVisibleCount === 0) {
                section.style.display = 'none';
            } else {
                section.style.display = 'flex';
            }
        });

        if (totalVisible === 0) {
            noResultsMsg.classList.remove('hidden');
        } else {
            noResultsMsg.classList.add('hidden');
        }
    }
</script>

<style>
    html { scroll-behavior: smooth; }
</style>