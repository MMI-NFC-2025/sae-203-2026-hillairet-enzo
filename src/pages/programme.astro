---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';

export const prerender = true;

// ==========================================
// 1. CONNEXION POCKETBASE (Serveur-side)
// ==========================================
const pb = new PocketBase('http://127.0.0.1:8090'); 

let concerts = [];
try {
    const records = await pb.collection('artistes').getFullList({
        sort: '+date_representation', 
    });

    const uniqueDates = [...new Set(records.map(r => r.date_representation.substring(0, 10)))].sort();

    concerts = records.map((record) => {
        const dateStr = record.date_representation.substring(0, 10);
        const dayNum = uniqueDates.indexOf(dateStr) + 1;

        return {
            id: record.id,
            nom: record.nom,
            genre: record.genre_musical,    
            scene: record.type_de_scene,    
            horaire: record.moment_journee,  
            jour: `Jour ${dayNum}`,          
            image: record.image_principale ? pb.files.getUrl(record, record.image_principale) : null 
        };
    });

} catch (err) {
    console.error("Erreur de connexion à PocketBase :", err);
    concerts = [
        { id: "1", nom: "Danakil", genre: "Reggae", scene: "Scène principale", horaire: "Soirée", jour: "Jour 1", image: "/assets/images/artistes/danakil.avif" },
        { id: "2", nom: "Tiken Jah Fakoly", genre: "Reggae", scene: "Scène principale", horaire: "Nuit", jour: "Jour 1", image: "/assets/images/artistes/tiken.avif" },
        { id: "4", nom: "Jahneration", genre: "Reggae", scene: "Scène principale", horaire: "Soirée", jour: "Jour 2", image: "/assets/images/artistes/jahneration.avif" },
        { id: "7", nom: "Dub Inc", genre: "Reggae", scene: "Scène principale", horaire: "Soirée", jour: "Jour 3", image: "/assets/images/artistes/dubinc.avif" },
    ];
}

// 2. LOGIQUE DES FILTRES
const groupedConcerts = {};
const genresSet = new Set(); 
const horairesSet = new Set();
const scenesSet = new Set();

concerts.forEach(c => {
    if(!groupedConcerts[c.jour]) groupedConcerts[c.jour] = [];
    groupedConcerts[c.jour].push(c);
    if(c.genre) genresSet.add(c.genre);
    if(c.horaire) horairesSet.add(c.horaire);
    if(c.scene) scenesSet.add(c.scene);
});

const days = Object.keys(groupedConcerts).sort();
const filtres = {
    genre: Array.from(genresSet).sort(),
    horaire: Array.from(horairesSet).sort(),
    scene: Array.from(scenesSet).sort()
};

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];

const programDays = [
    { title: "Jour 1", img: "/assets/images/artistes/danakil.avif", date: "Vendredi 29 Octobre" },
    { title: "Jour 2", img: "/assets/images/artistes/jahneration.avif", date: "Samedi 30 Octobre" },
    { title: "Jour 3", img: "/assets/images/artistes/dub-inc.avif", date: "Dimanche 31 Octobre" }
];
---

<Layout title="Programme | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen font-poppins">
        
        <div id="menu-overlay" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out md:left-auto md:w-[500px] lg:w-[600px]">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" />
                <div class="absolute inset-0 bg-gradient-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-10">
                    <ul class="space-y-4 md:space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li>
                                <a href={link.href} class="block text-2xl md:text-4xl lg:text-5xl font-bold text-white uppercase tracking-tight hover:text-[#FED506] transition-colors whitespace-nowrap">
                                    {link.name} <span class="text-white ml-2 md:ml-4">•</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 lg:px-12 xl:px-16 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" />
            </a>
            
            <div class="flex items-center gap-4">
                <button id="user-status-connected" class="hidden text-[10px] md:text-xs lg:text-sm uppercase font-bold bg-[#6d9a02] text-white px-4 py-2 lg:px-6 lg:py-3 rounded-full shadow-lg hover:bg-red-600 transition-colors group">
                    <span class="group-hover:hidden">Connecté</span>
                    <span class="hidden group-hover:inline">Déconnexion</span>
                </button>

                <a href="/connexion" id="user-status-disconnected" class="text-[10px] md:text-xs lg:text-sm uppercase font-bold bg-[#ED3F24] text-white px-4 py-2 lg:px-6 lg:py-3 rounded-full shadow-lg hover:scale-105 transition-transform">
                    Se connecter
                </a>

                <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group hover:opacity-70 transition-opacity">
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                    <div class="w-10 md:w-14 h-1 bg-black rounded-full transition-all"></div>
                </button>
            </div>
        </header>

        <section class="relative w-full overflow-hidden bg-black lg:h-[60vh] flex flex-col justify-center">
            <img src="/assets/images/hero.avif" alt="Hero Programme" class="absolute inset-0 w-full h-full object-cover opacity-60" />
            <div class="relative z-10 flex flex-col items-center justify-center p-6 text-center lg:min-h-full w-full">
                <h1 class="font-display text-5xl md:text-8xl lg:text-[10rem] tracking-wider leading-[0.9] text-center uppercase" 
                    style="color: #ED3F24; -webkit-text-stroke: 3px #FED506; text-shadow: none;">
                    Notre Programme
                </h1>
                <a href="/assets/programme.pdf" download class="mt-8 md:mt-12 font-poppins font-bold text-white uppercase tracking-widest border-b-2 border-white hover:text-[#FED506] hover:border-[#FED506] transition-all text-sm md:text-xl lg:text-2xl">
                    Téléchargement PDF
                </a>
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#ED3F24] relative z-40 shadow-lg"></div>

        <section class="w-full py-12 md:py-24 px-4 md:px-10 flex flex-col items-center">
            <div class="w-full max-w-7xl flex flex-col md:flex-row items-stretch justify-center gap-6 md:gap-8 lg:gap-12">
                {programDays.map((day, index) => (
                    <>
                        <div class="group relative w-full md:flex-1 h-48 sm:h-56 md:h-[450px] lg:h-auto lg:aspect-square rounded-2xl overflow-hidden shadow-xl transition-all duration-500 hover:scale-[1.03] cursor-pointer" onclick={`filterByDay('${day.title}')`}>
                            <img src={day.img} alt={day.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                            <div class="absolute bottom-4 left-6 md:bottom-8 md:left-8 lg:bottom-10 lg:left-10">
                                <h3 class="font-poppins font-bold text-2xl md:text-4xl text-white uppercase tracking-widest group-hover:text-[#FED506] transition-colors">{day.title}</h3>
                                <p class="font-poppins text-white/70 text-xs md:text-lg uppercase tracking-wider mt-1">{day.date}</p>
                            </div>
                        </div>
                        {index < programDays.length - 1 && (
                            <div class="w-full block md:hidden py-2">
                                <img src="/assets/images/lignes_rouge_jaune_vert.svg" alt="separateur" class="w-full h-auto opacity-60" />
                            </div>
                        )}
                    </>
                ))}
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#FED506] relative z-40 shadow-lg"></div>

        <section class="w-full bg-[#1e1e1e] py-16 md:py-20 flex flex-col items-center shadow-inner relative z-30">
            <h2 class="font-righteous text-4xl md:text-5xl lg:text-6xl text-white mb-12 tracking-widest text-center uppercase">Filtres</h2>
            
            <div class="flex flex-wrap justify-center gap-8 md:gap-16 lg:gap-24 font-poppins font-bold text-white text-lg md:text-2xl lg:text-3xl mb-8">
                {filtres.genre.length > 0 && (
                    <button class="hover:text-[#FED506] transition-colors flex items-center gap-2" onclick="toggleSubFilters('genre')">
                        Genre <span id="arrow-genre" class="text-sm">▼</span>
                    </button>
                )}
                {filtres.horaire.length > 0 && (
                    <button class="hover:text-[#FED506] transition-colors flex items-center gap-2" onclick="toggleSubFilters('horaire')">
                        Horaire <span id="arrow-horaire" class="text-sm">▼</span>
                    </button>
                )}
                {filtres.scene.length > 0 && (
                    <button class="hover:text-[#FED506] transition-colors flex items-center gap-2" onclick="toggleSubFilters('scene')">
                        Scène <span id="arrow-scene" class="text-sm">▼</span>
                    </button>
                )}
            </div>

            <div class="min-h-[60px] flex flex-col items-center w-full px-6">
                <div id="options-genre" class="filter-group hidden flex flex-wrap justify-center gap-4 max-w-4xl">
                    {filtres.genre.map(g => (
                        <button class="filter-btn px-6 py-2 border border-white/40 rounded-xl bg-[#333333] text-white font-poppins text-sm md:text-base lg:text-lg hover:bg-white hover:text-black transition-all" data-type="genre" data-value={g}>{g}</button>
                    ))}
                </div>
                <div id="options-horaire" class="filter-group hidden flex flex-wrap justify-center gap-4 max-w-4xl">
                    {filtres.horaire.map(h => (
                        <button class="filter-btn px-6 py-2 border border-white/40 rounded-xl bg-[#333333] text-white font-poppins text-sm md:text-base lg:text-lg hover:bg-white hover:text-black transition-all" data-type="horaire" data-value={h}>{h}</button>
                    ))}
                </div>
                <div id="options-scene" class="filter-group hidden flex flex-wrap justify-center gap-4 max-w-4xl">
                    {filtres.scene.map(s => (
                        <button class="filter-btn px-6 py-2 border border-white/40 rounded-xl bg-[#333333] text-white font-poppins text-sm md:text-base lg:text-lg hover:bg-white hover:text-black transition-all" data-type="scene" data-value={s}>{s}</button>
                    ))}
                </div>
                <button id="reset-filters" class="hidden mt-8 px-8 py-3 border border-[#FED506] text-[#FED506] rounded-xl font-poppins font-bold text-sm md:text-base uppercase hover:bg-[#FED506] hover:text-black transition-all">
                    Tout afficher
                </button>
            </div>
        </section>

        <div id="concerts-grid" class="w-full flex flex-col">
            {days.length === 0 ? (
                 <div class="w-full py-20 text-center text-black font-poppins text-2xl">
                    Aucun concert trouvé.
                 </div>
            ) : (
                days.map((day, index) => {
                    const isLight = index % 2 !== 0; 
                    let bgImage = index % 2 === 0 ? '/assets/images/section-background.avif' : null;
                    if (day === 'Jour 3') bgImage = '/assets/images/licorn-bg.avif';
                    
                    return (
                        <section class={`day-section relative w-full py-20 lg:py-32 flex flex-col items-center overflow-hidden min-h-[500px] ${isLight ? 'bg-[#FEFAF5]' : ''}`} data-day-section={day}>
                            {!isLight && bgImage && (
                                <div class="absolute inset-0 z-0">
                                    <img src={bgImage} alt="Ambiance" class="w-full h-full object-cover absolute" />
                                    <div class="absolute inset-0 bg-black/75"></div>
                                </div>
                            )}

                            <div class="relative z-10 w-full max-w-7xl px-6 flex flex-col items-center lg:items-start">
                                <h2 class={`font-righteous text-5xl md:text-7xl lg:text-7xl mb-12 md:mb-16 tracking-widest uppercase ${isLight ? 'text-black' : 'text-white'}`}>
                                    {day}
                                </h2>
                                
                                <div class="w-full grid grid-cols-1 lg:grid-cols-3 gap-x-8 gap-y-6 lg:gap-y-10">
                                    {groupedConcerts[day].map((concert) => (
                                        <div class="concert-wrapper w-full flex flex-col items-center" 
                                             data-scene={concert.scene} 
                                             data-genre={concert.genre} 
                                             data-horaire={concert.horaire}
                                             data-jour={concert.jour}>
                                            
                                            <a href={`/artistes/${concert.id}`} class="relative w-full h-[220px] md:h-[400px] lg:h-auto lg:aspect-square rounded-3xl overflow-hidden shadow-2xl group block cursor-pointer">
                                                <img src={concert.image || "/assets/images/section-background.avif"} alt={concert.nom} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                                                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-90"></div>
                                                
                                                <div class="absolute top-5 left-6 md:top-8 md:left-8 lg:top-8 lg:left-8">
                                                    <h3 class="font-poppins font-bold text-2xl md:text-5xl lg:text-2xl xl:text-3xl text-white tracking-wide uppercase leading-tight mb-4 group-hover:text-[#FED506] transition-colors">{concert.nom}</h3>
                                                </div>
                                                
                                                <div class="absolute bottom-5 right-6 md:bottom-8 md:right-8 lg:bottom-8 lg:right-8 flex flex-col items-end gap-2 lg:opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                                    <span class="inline-block px-3 py-1 bg-[#FED506] text-black font-bold text-xs md:text-sm lg:text-xs rounded-full uppercase tracking-widest shadow-lg">{concert.horaire}</span>
                                                    <span class="inline-block px-3 py-1 bg-black/60 text-white font-poppins text-xs md:text-sm lg:text-xs rounded-full uppercase tracking-widest backdrop-blur-md">{concert.scene}</span>
                                                </div>
                                            </a>

                                            <div class="w-full mt-10 mb-4 lg:hidden flex justify-center">
                                                <img src="/assets/images/lignes_rouge_jaune_vert.svg" alt="séparateur" class="w-full h-auto opacity-90" />
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </section>
                    );
                })
            )}
            <div id="no-results" class="hidden text-white font-poppins text-xl md:text-2xl my-16 text-center bg-[#1e1e1e] border border-[#FED506] px-8 py-4 rounded-2xl shadow-xl mx-auto max-w-max">
                Aucun artiste ne correspond à ces filtres.
            </div>
        </div>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#6d9a02] relative z-40 shadow-lg"></div>

        <footer class="w-full bg-black text-white pt-16 pb-12 flex flex-col items-center overflow-hidden z-30 border-t border-white/10">
            <div class="w-full max-w-7xl flex flex-col items-center lg:items-start px-6">
                
                <div class="w-full font-poppins text-xs md:text-base opacity-60 space-y-1 mt-12 mb-12 text-center lg:text-left flex flex-col lg:flex-row lg:justify-between">
                    <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                    <p>Par Maël BRUNGARD @BooMooN.cloud | ID : o4g3yq8bkgg4bxz</p>
                </div>

                <div class="w-full flex flex-col lg:flex-row lg:justify-between items-center">
                    <nav class="mb-12 lg:mb-0">
                        <ul class="flex flex-wrap justify-center lg:justify-start items-center gap-x-12 gap-y-6 font-poppins font-bold text-sm md:text-xl uppercase">
                            {navLinks.map((link, i) => (
                                <li class="flex items-center gap-12">
                                    <a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a>
                                    {i < navLinks.length - 1 && <span class="opacity-20 hidden md:block select-none">•</span>}
                                </li>
                            ))}
                        </ul>
                    </nav>

                    <nav class="flex gap-10 font-poppins text-[10px] md:text-xs uppercase underline opacity-40">
                        <a href="#">CGU</a><a href="#">CGV</a><a href="#">Mentions Légales</a>
                    </nav>
                </div>
            </div>
        </footer>
    </div>
</Layout>

<script>
    import { pb, logoutUser } from '../../backend/backend.mjs';

    // --- MENU ---
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');
    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { 
            overlay.classList.remove('translate-x-full'); 
            document.body.style.overflow = 'hidden'; 
        });
        menuClose.addEventListener('click', () => { 
            overlay.classList.add('translate-x-full'); 
            document.body.style.overflow = ''; 
        });
    }

    // --- BOUTONS STATUT ---
    const btnConnected = document.getElementById('user-status-connected');
    const btnDisconnected = document.getElementById('user-status-disconnected');

    function updateHeader() {
        if (pb && pb.authStore && pb.authStore.isValid) {
            btnConnected?.classList.remove('hidden');
            btnDisconnected?.classList.add('hidden');
        } else {
            btnConnected?.classList.add('hidden');
            btnDisconnected?.classList.remove('hidden');
        }
    }

    btnConnected?.addEventListener('click', () => {
        if(typeof logoutUser === 'function') logoutUser();
        else pb.authStore.clear();
        window.location.reload();
    });

    updateHeader();

    // --- FILTRES ---
    let activeGroup = null;
    (window as any).toggleSubFilters = function(group) {
        document.querySelectorAll('.filter-group').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('span[id^="arrow-"]').forEach(el => (el as HTMLElement).innerText = '▼');
        if (activeGroup === group) { activeGroup = null; } 
        else {
            document.getElementById(`options-${group}`)?.classList.remove('hidden');
            const arrow = document.getElementById(`arrow-${group}`);
            if (arrow) arrow.innerText = '▲';
            activeGroup = group;
        }
    }

    const filterBtns = document.querySelectorAll('.filter-btn');
    const daySections = document.querySelectorAll('.day-section');
    const resetBtn = document.getElementById('reset-filters');
    const noResultsMsg = document.getElementById('no-results');

    let currentFilterType = null;
    let currentFilterValue = null;
    let currentDayFilter = null; 

    (window as any).filterByDay = function(dayTitle) {
        currentDayFilter = dayTitle;
        resetBtn?.classList.remove('hidden');
        applyFilters();
        document.getElementById('concerts-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            const target = e.currentTarget as HTMLButtonElement;
            const type = target.getAttribute('data-type');
            const val = target.getAttribute('data-value');
            
            if (currentFilterType === type && currentFilterValue === val) {
                currentFilterType = null;
                currentFilterValue = null;
                target.classList.replace('bg-white', 'bg-[#333333]');
                target.classList.replace('text-black', 'text-white');
            } else {
                filterBtns.forEach(b => {
                    b.classList.replace('bg-white', 'bg-[#333333]');
                    b.classList.replace('text-black', 'text-white');
                });
                target.classList.replace('bg-[#333333]', 'bg-white');
                target.classList.replace('text-white', 'text-black');
                currentFilterType = type;
                currentFilterValue = val;
            }
            
            resetBtn?.classList.remove('hidden');
            applyFilters();
        });
    });

    resetBtn?.addEventListener('click', () => {
        currentFilterType = currentFilterValue = currentDayFilter = null;
        filterBtns.forEach(b => {
            b.classList.replace('bg-white', 'bg-[#333333]');
            b.classList.replace('text-black', 'text-white');
        });
        resetBtn.classList.add('hidden');
        applyFilters();
    });

    function applyFilters() {
        let totalVisible = 0;
        daySections.forEach(section => {
            let sectionVisibleCount = 0;
            const wrappers = section.querySelectorAll('.concert-wrapper');
            wrappers.forEach(wrapper => {
                let show = true;
                if (currentFilterType && wrapper.getAttribute(`data-${currentFilterType}`) !== currentFilterValue) show = false;
                if (currentDayFilter && wrapper.getAttribute('data-jour') !== currentDayFilter) show = false;
                (wrapper as HTMLElement).style.display = show ? 'flex' : 'none';
                if (show) sectionVisibleCount++;
            });
            (section as HTMLElement).style.display = sectionVisibleCount > 0 ? 'flex' : 'none';
            totalVisible += sectionVisibleCount;
        });
        if (noResultsMsg) noResultsMsg.style.display = totalVisible === 0 ? 'block' : 'none';
    }
</script>

<style>
    html { scroll-behavior: smooth; }
</style>