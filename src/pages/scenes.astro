---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';

// ==========================================
// 1. CONNEXION POCKETBASE
// ==========================================
const pb = new PocketBase('http://127.0.0.1:8090');

let scenes = [];

try {
    const records = await pb.collection('scenes').getFullList({
        sort: '+nom', 
    });

    if (records.length === 0) {
        throw new Error("Base vide");
    }

    scenes = records.map((record) => {
        let imageForcee = null;
        if (record.nom === "Scène 1") imageForcee = "/assets/images/artistes/danakil.avif";
        if (record.nom === "Scène 2") imageForcee = "/assets/images/artistes/tiken-jah-fakoly.avif"; 
        if (record.nom === "Scène 3") imageForcee = "/assets/images/artistes/bigaranx.avif";

        return {
            id: record.id,
            nom: record.nom,
            lieu: record.lieu,
            description: record.description, 
            capacite: record.capacite,       
            image: imageForcee || (record.image ? pb.files.getUrl(record, record.image) : null)
        };
    });

} catch (err) {
    console.warn("Utilisation des données de secours.");
    scenes = [
        { id: "1", nom: "Scène 1", lieu: "OUEST", capacite: 8000, description: "Le cœur battant du festival...", image: "/assets/images/artistes/danakil.avif" },
        { id: "2", nom: "Scène 2", lieu: "NORD", capacite: 3500, description: "Une scène entourée d'installations...", image: "/assets/images/artistes/tiken-jah-fakoly.avif" },
        { id: "3", nom: "Scène 3", lieu: "SUD", capacite: 1200, description: "Une scène plus proche de la nature...", image: "/assets/images/artistes/bigaranx.avif" }
    ];
}

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];
---

<Layout title="Nos Scènes | Echos Sonore">
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen">
        
        <div id="menu-overlay" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" onerror="this.style.display='none'" />
                <div class="absolute inset-0 bg-gradient-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/connexion"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-20">
                    <ul class="space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li>
                                <a href={link.href} class="block text-2xl md:text-5xl font-poppins font-bold text-white uppercase hover:text-[#FED506] transition-colors">
                                    {link.name} <span class="text-white ml-2 md:ml-4">•</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 z-50 bg-[#FFF4C6]">
            <a href="/connexion" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" />
            </a>
            <div class="flex items-center gap-4">
                <span id="user-status" class="hidden font-poppins text-[10px] md:text-xs uppercase font-bold bg-[#6d9a02] text-white px-4 py-1.5 rounded-full shadow-lg animate-pulse">Connecté</span>
                <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group">
                    <div class="w-10 md:w-12 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                    <div class="w-10 md:w-12 h-1 bg-black rounded-full transition-all"></div>
                </button>
            </div>
        </header>

        <section class="relative w-full h-72 md:h-96 overflow-hidden bg-black">
            <img src="/assets/images/hero.avif" alt="Platine Vinyle" class="absolute inset-0 w-full h-full object-cover opacity-60" />
            <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center bg-black/40">
                <h1 class="font-display text-5xl sm:text-7xl md:text-[10rem] text-[#FED506] uppercase italic leading-none drop-shadow-[0_4px_0_rgba(185,28,28,1)] md:drop-shadow-[0_8px_0_rgba(185,28,28,1)]">
                    Nos Scènes
                </h1>
            </div>
        </section>

        <section class="w-full py-16 md:py-28 px-6 md:px-10 flex flex-col items-center flex-1">
            <div class="w-full max-w-4xl flex flex-col gap-8 md:gap-12">
                {scenes.map((scene) => (
                    <a href={`/scenes/${scene.id}`} class="block group relative w-full h-56 sm:h-64 md:h-80 bg-gray-900 rounded-[2.5rem] overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-500 border border-black/10 cursor-pointer">
                        
                        <img src={scene.image || "/assets/images/section-background.avif"} alt={scene.nom} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                        
                        <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/50 to-transparent opacity-80 group-hover:opacity-95 transition-opacity duration-500"></div>
                        <div class="absolute inset-0 bg-black/10 group-hover:bg-black/30 transition-all duration-500"></div>
                        
                        <div class="absolute top-6 left-6 md:top-10 md:left-10 flex flex-col gap-2 md:gap-4 transition-transform duration-500 group-hover:translate-y-1 z-10">
                            <h2 class="font-poppins font-bold text-3xl md:text-5xl text-white tracking-wide">{scene.nom}</h2>
                            <p class="font-poppins font-bold text-lg md:text-2xl text-white tracking-wide">
                                Lieu : {scene.lieu}
                            </p>
                        </div>

                        <div class="absolute bottom-6 left-6 md:bottom-10 md:left-10 pr-8 opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 max-w-[85%] md:max-w-[70%] z-10">
                            {scene.capacite && (
                                <p class="font-poppins text-xs md:text-sm text-white/80 uppercase tracking-widest mb-1 md:mb-2">
                                    Capacité : <span class="font-bold text-[#FED506]">{scene.capacite} personnes</span>
                                </p>
                            )}
                            {scene.description && (
                                <p class="font-poppins text-sm md:text-base text-white/90 leading-relaxed line-clamp-2 md:line-clamp-3">
                                    {scene.description}
                                </p>
                            )}
                        </div>
                    </a>
                ))}
            </div>
        </section>

        <footer class="w-full bg-black text-white pt-24 pb-12 flex flex-col items-center overflow-hidden z-30 mt-auto">
            <div class="font-poppins text-[10px] sm:text-xs md:text-base opacity-40 mb-12 text-center text-balance px-4 leading-relaxed">
                <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                <p>Par Maël BRUNGARD @BooMooN.cloud | ID : o4g3yq8bkgg4bxz</p>
            </div>
            <nav class="mb-12 px-4 text-center">
                <ul class="flex flex-wrap justify-center items-center gap-x-6 sm:gap-x-12 gap-y-6 font-poppins font-bold text-xs sm:text-sm md:text-xl uppercase">
                    {navLinks.map((link, i) => (
                        <li class="flex items-center gap-6 sm:gap-12">
                            <a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a>
                            {i < navLinks.length - 1 && <span class="opacity-20 hidden md:block select-none">•</span>}
                        </li>
                    ))}
                </ul>
            </nav>
            <nav class="flex flex-wrap justify-center gap-6 sm:gap-10 font-poppins text-[9px] sm:text-[10px] md:text-xs uppercase underline opacity-40 text-center px-4">
                <a href="#">CGU</a><a href="#">CGV</a><a href="#">Mentions Légales</a>
            </nav>
        </footer>
    </div>
</Layout>

<script>
    // --- MENU ---
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');
    
    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { 
            overlay.classList.remove('translate-x-full'); 
            document.body.style.overflow = 'hidden'; 
        });
        menuClose.addEventListener('click', () => { 
            overlay.classList.add('translate-x-full'); 
            document.body.style.overflow = ''; 
        });
    }

    // --- STATUT CONNEXION ---
    import { pb } from '../../backend/backend.mjs';
    const userStatus = document.getElementById('user-status');
    if (pb.authStore.isValid && userStatus) {
        userStatus.classList.remove('hidden');
    }
</script>

<style>
    html { scroll-behavior: smooth; }
</style>