---
import Layout from '../../layouts/Layout.astro';
import PocketBase from 'pocketbase';

export const prerender = true;

// ==========================================
// 1. GÉNÉRATION DES CHEMINS (Static Paths)
// ==========================================
export async function getStaticPaths() {
    // Remplacement par l'URL en ligne
    const pb = new PocketBase('https://echosonore.hillairet.optimiseus.fr');
    
    try {
        const records = await pb.collection('scenes').getFullList();
        if (records.length === 0) throw new Error("Base vide");

        return records.map((record) => ({
            params: { id: record.id },
            props: { scene: record }
        }));
    } catch (err) {
        console.warn("Utilisation des scènes de secours pour la génération.");
        return [
            { params: { id: '1' }, props: { scene: { id: '1', nom: 'Scène 1', lieu: 'OUEST', imageDeSecours: '/assets/images/artistes/danakil.avif', galerieDeSecours: [] } } },
            { params: { id: '2' }, props: { scene: { id: '2', nom: 'Scène 2', lieu: 'NORD', imageDeSecours: '/assets/images/artistes/tiken-jah-fakoly.avif', galerieDeSecours: [] } } },
            { params: { id: '3' }, props: { scene: { id: '3', nom: 'Scène 3', lieu: 'SUD', imageDeSecours: '/assets/images/artistes/bigaranx.avif', galerieDeSecours: [] } } }
        ];
    }
}

// ==========================================
// 2. RÉCUPÉRATION DES DONNÉES (Scène + Artistes)
// ==========================================
const { scene } = Astro.props;
// Remplacement par l'URL en ligne
const pb = new PocketBase('https://echosonore.hillairet.optimiseus.fr');

// IMAGE DE LA SCÈNE (Champ "image" de la collection scenes)
let sceneImage = '/assets/images/section-background.avif';
if ((scene as any)?.image) {
    sceneImage = pb.files.getUrl(scene, (scene as any).image);
} else if (scene?.imageDeSecours) {
    sceneImage = scene.imageDeSecours;
}

// GALERIE PHOTOS
let galleryImages: any[] = [];
if ((scene as any)?.galerie && Array.isArray((scene as any).galerie) && (scene as any).galerie.length > 0) {
    galleryImages = (scene as any).galerie.map((img: any) => pb.files.getUrl(scene, img));
} else if (scene?.galerieDeSecours) {
    galleryImages = scene.galerieDeSecours;
}

// ARTISTES DE CETTE SCÈNE
let artistesAssocies: any[] = [];
try {
    const tousArtistes = await pb.collection('artistes').getFullList();
    
    const artistesFiltres = tousArtistes.filter(a => {
        if (!a.scene) return false;
        if (Array.isArray(a.scene)) return a.scene.includes(scene.id);
        return a.scene === scene.id;
    });

    artistesAssocies = artistesFiltres.map(record => {
        let formattedDate = "Date à venir";
        if (record.date_representation) {
            const dateObj = new Date(record.date_representation);
            formattedDate = dateObj.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
        }
        return {
            id: record.id,
            nom: record.nom,
            date: formattedDate,
            // IMAGE DE L'ARTISTE (Champ "image_principale" de la collection artistes)
            image: record.image_principale ? pb.files.getUrl(record, record.image_principale) : null
        };
    });
} catch (err) {
    console.warn("Impossible de récupérer les artistes.");
}

const navLinks = [
    { name: "Le Festival", href: "/festival" },
    { name: "Programme", href: "/programme" },
    { name: "Artistes", href: "/artistes" },
    { name: "Scènes", href: "/scenes" },
    { name: "Infos pratiques", href: "/infos-pratiques" },
    { name: "Contact", href: "/contact" }
];
---

<Layout title={scene ? `${scene.nom} | Echos Sonore` : "Scène"}>
    <div class="w-full flex flex-col overflow-x-hidden bg-[#FFF4C6] min-h-screen">
        
        <div id="menu-overlay" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out md:left-auto md:w-[500px] lg:w-[600px]">
            <div class="absolute inset-0 bg-black">
                <img src="/assets/images/licorn-bg.avif" alt="Menu BG" class="w-full h-full object-cover opacity-50" />
                <div class="absolute inset-0 bg-gradient-to-l from-black/80 to-transparent"></div>
            </div>
            <div class="relative z-10 h-full flex flex-col p-6 md:p-10">
                <div class="flex justify-between items-center w-full">
                    <a href="/"><img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" /></a>
                    <button id="menu-close" class="text-white p-2 cursor-pointer hover:rotate-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <nav class="flex-1 flex flex-col justify-start pt-32 items-end pr-4 md:pr-10">
                    <ul class="space-y-6 text-right">
                        {navLinks.map((link) => (
                            <li><a href={link.href} class="block text-2xl md:text-4xl lg:text-5xl font-poppins font-bold text-white uppercase hover:text-[#FED506] transition-colors whitespace-nowrap">{link.name} <span class="text-white ml-2 md:ml-4">•</span></a></li>
                        ))}
                    </ul>
                </nav>
            </div>
        </div>

        <header class="w-full flex justify-between items-center p-6 md:p-10 lg:px-12 xl:px-16 z-50 bg-[#FFF4C6]">
            <a href="/" class="hover:scale-110 transition-transform">
                <img src="/assets/icons/logo.avif" alt="Logo" class="h-14 md:h-20 w-auto rounded-2xl" />
            </a>
            <div class="flex items-center gap-4">
                <button id="user-status-connected" class="hidden font-poppins text-[10px] md:text-xs uppercase font-bold bg-[#6d9a02] text-white px-3 py-1.5 rounded-full shadow-lg animate-pulse hover:bg-red-600 transition-colors group">
                    <span class="group-hover:hidden">Connecté</span>
                    <span class="hidden group-hover:inline">Déconnexion</span>
                </button>
                <a href="/connexion" id="user-status-disconnected" class="font-poppins text-[10px] md:text-xs uppercase font-bold bg-[#ED3F24] text-white px-3 py-1.5 rounded-full shadow-lg hover:scale-105 transition-transform">
                    Se connecter
                </a>
                <button id="menu-open" class="flex flex-col gap-2 p-2 cursor-pointer items-end group">
                    <div class="w-10 md:w-12 h-1 bg-black rounded-full group-hover:w-8 transition-all"></div>
                    <div class="w-10 md:w-12 h-1 bg-black rounded-full transition-all"></div>
                </button>
            </div>
        </header>

        <section class="relative w-full h-56 sm:h-72 md:h-[400px] overflow-hidden bg-black">
            <img src={sceneImage} alt={scene?.nom} class="absolute inset-0 w-full h-full object-cover opacity-80" />
            <div class="absolute inset-0 flex items-center justify-center p-4 bg-black/20">
                <h1 class="font-display text-4xl sm:text-6xl md:text-8xl text-white tracking-widest text-center" style="text-shadow: 2px 2px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000;">
                    {scene?.nom} {scene?.lieu ? `- ${scene.lieu}` : ''}
                </h1>
            </div>
        </section>

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#ED3F24] relative z-40 shadow-lg"></div>

        <section class="w-full py-16 md:py-28 px-6 md:px-10 flex flex-col items-center flex-1">
            
            <h2 class="font-righteous text-4xl md:text-5xl lg:text-6xl text-black tracking-widest mb-12 text-center uppercase">
                Les Artistes sur scène
            </h2>
            
            {artistesAssocies.length > 0 ? (
                <div class="w-full max-w-5xl flex flex-col items-center gap-6 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-x-12 md:gap-y-16">
                    {artistesAssocies.map((artiste: any, i: number) => (
                        <>
                            {i > 0 && (
                                <div class="w-full h-auto md:hidden">
                                    <img src="/assets/images/lignes_rouge_jaune_vert.svg" alt="séparateur" class="w-full h-auto object-cover" />
                                </div>
                            )}
                            <a href={`/artistes/${artiste.id}`} class="group relative block w-full aspect-[16/10] md:aspect-square rounded-[1.5rem] overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 border border-black/10 cursor-pointer flex-shrink-0">
                                
                                <img src={artiste.image || "/assets/images/section-background.avif"} alt={artiste.nom} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                                
                                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-all duration-500"></div>
                                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-90"></div>
                                
                                <div class="absolute top-4 left-4 md:top-6 md:left-6 flex flex-col gap-1 transition-transform duration-500 z-10">
                                    <h3 class="font-poppins font-bold text-xl md:text-3xl text-white tracking-wide drop-shadow-md group-hover:text-[#FED506] transition-colors">{artiste.nom}</h3>
                                </div>

                                <div class="absolute bottom-4 left-4 md:bottom-6 md:left-6 z-10">
                                    <p class="font-poppins font-bold text-xs md:text-sm text-white tracking-widest drop-shadow-md">
                                        Date : {artiste.date}
                                    </p>
                                </div>
                            </a>
                        </>
                    ))}
                </div>
            ) : (
                <div class="bg-white/50 backdrop-blur-sm rounded-[2rem] p-10 text-center w-full max-w-2xl mx-auto border border-black/10 shadow-sm">
                    <p class="font-poppins text-lg text-black/60 italic">Aucun artiste n'est encore programmé sur cette scène.</p>
                </div>
            )}
        </section>

        {galleryImages.length > 0 && (
            <div class="w-full h-4 md:h-6 lg:h-8 bg-[#FED506] relative z-40 shadow-lg"></div>
        )}

        {galleryImages.length > 0 && (
            <section class="relative w-full py-20 md:py-32 overflow-hidden">
                <div class="absolute inset-0 z-0">
                    <img src={sceneImage} alt="" class="w-full h-full object-cover blur-xl scale-110 opacity-50" />
                    <div class="absolute inset-0 bg-black/80"></div>
                </div>

                <div class="relative z-10 w-full max-w-6xl mx-auto flex flex-col items-center">
                    
                    <h2 class="font-righteous text-4xl md:text-5xl lg:text-6xl text-white mb-16 tracking-widest text-center px-6 uppercase">
                        Galerie Photos
                    </h2>
                    
                    <div class="relative w-full group px-12 md:px-20">
                        <div class="overflow-hidden w-full">
                            <div id="carousel-track" class="flex transition-transform duration-500 ease-in-out">
                                {galleryImages.map((img: any) => (
                                    <div class="carousel-item w-full sm:w-1/2 md:w-1/3 flex-shrink-0 px-2 sm:px-4">
                                        <div class="w-full h-64 md:h-80 rounded-3xl overflow-hidden shadow-2xl border border-white/10">
                                            <img src={img} alt={`Galerie ${scene?.nom}`} class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <button id="btn-prev" class="absolute top-1/2 left-2 md:left-6 -translate-y-1/2 bg-black/50 hover:bg-[#FED506] hover:text-black text-white p-3 md:p-4 rounded-full backdrop-blur-md transition-all shadow-xl z-20 hidden border border-white/20">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                        </button>

                        <button id="btn-next" class="absolute top-1/2 right-2 md:right-6 -translate-y-1/2 bg-black/50 hover:bg-[#FED506] hover:text-black text-white p-3 md:p-4 rounded-full backdrop-blur-md transition-all shadow-xl z-20 border border-white/20">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                        </button>
                    </div>
                </div>
            </section>
        )}

        <div class="w-full h-4 md:h-6 lg:h-8 bg-[#6d9a02] relative z-40 shadow-lg"></div>

        <footer class="w-full bg-black text-white pt-16 pb-12 flex flex-col items-center mt-auto border-t border-white/10">
            <div class="font-poppins text-[10px] sm:text-xs md:text-base opacity-40 mb-12 text-center text-balance px-4 leading-relaxed">
                <p>MMI 1ère année — SAE 105 — Montbéliard</p>
                <p>Par Maël BRUNGARD @BooMooN.cloud | ID Étudiant : o4g3yq8bkgg4bxz</p>
            </div>
            <nav class="mb-12 px-4">
                <ul class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6 font-poppins font-bold text-sm md:text-xl uppercase">
                    {navLinks.map((link, i) => (
                        <li class="flex items-center gap-12">
                            <a href={link.href} class="hover:text-[#FED506] transition-all hover:tracking-widest">{link.name}</a>
                            {i < navLinks.length - 1 && <span class="opacity-20 hidden md:block select-none">•</span>}
                        </li>
                    ))}
                </ul>
            </nav>
        </footer>
    </div>
</Layout>

<script>
    import { pb, logoutUser } from '../../../backend/backend.mjs';

    // --- MENU ---
    const menuOpen = document.getElementById('menu-open');
    const menuClose = document.getElementById('menu-close');
    const overlay = document.getElementById('menu-overlay');
    if (menuOpen && menuClose && overlay) {
        menuOpen.addEventListener('click', () => { overlay.classList.remove('translate-x-full'); document.body.style.overflow = 'hidden'; });
        menuClose.addEventListener('click', () => { overlay.classList.add('translate-x-full'); document.body.style.overflow = ''; });
    }

    // --- BOUTONS STATUT ---
    const btnConnected = document.getElementById('user-status-connected');
    const btnDisconnected = document.getElementById('user-status-disconnected');

    if (pb && pb.authStore && pb.authStore.isValid) {
        btnConnected?.classList.remove('hidden');
        btnDisconnected?.classList.add('hidden');
    } else {
        btnConnected?.classList.add('hidden');
        btnDisconnected?.classList.remove('hidden');
    }

    btnConnected?.addEventListener('click', () => {
        if(typeof logoutUser === 'function') logoutUser();
        else pb.authStore.clear();
        window.location.reload();
    });

    // --- CAROUSEL GALERIE ---
    const track = document.getElementById('carousel-track');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');

    if (track && btnPrev && btnNext) {
        let currentIndex = 0;
        const items = track.querySelectorAll('.carousel-item');
        const totalItems = items.length;

        const updateCarousel = () => {
            if (totalItems === 0 || !track.parentElement) return;
            const itemWidth = items[0].getBoundingClientRect().width;
            track.style.transform = `translateX(-${currentIndex * itemWidth}px)`;

            const trackContainerWidth = track.parentElement.getBoundingClientRect().width;
            const visibleItems = Math.round(trackContainerWidth / itemWidth);

            if (currentIndex === 0) btnPrev.classList.add('hidden');
            else btnPrev.classList.remove('hidden');

            if (currentIndex >= totalItems - visibleItems) btnNext.classList.add('hidden');
            else btnNext.classList.remove('hidden');
        };

        btnNext.addEventListener('click', () => {
            if (!track.parentElement) return;
            const itemWidth = items[0].getBoundingClientRect().width;
            const trackContainerWidth = track.parentElement.getBoundingClientRect().width;
            const visibleItems = Math.round(trackContainerWidth / itemWidth);
            if (currentIndex < totalItems - visibleItems) { currentIndex++; updateCarousel(); }
        });

        btnPrev.addEventListener('click', () => {
            if (currentIndex > 0) { currentIndex--; updateCarousel(); }
        });

        window.addEventListener('resize', () => { currentIndex = 0; updateCarousel(); });
        updateCarousel();
    }
</script>

<style>
    html { scroll-behavior: smooth; }
</style>